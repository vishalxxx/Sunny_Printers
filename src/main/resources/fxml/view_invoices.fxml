<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/23"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="controller.ViewInvoicesController" spacing="20"
	stylesheets="@../css/view_job.css" styleClass="view-clients-root">

	<!-- PAGE TITLE -->
	<Label text="View Invoices" styleClass="page-heading" />

	<!-- ACTION BUTTONS -->
	<HBox spacing="10" alignment="CENTER_LEFT" styleClass="action-bar">
		<Button fx:id="btnEdit" text="Edit" onAction="#handleEditAction" disable="true"/>
		<Button fx:id="btnFinalize" text="Finalize" onAction="#handleFinalizeAction" disable="true"/>
		<Button fx:id="btnSend" text="Send" onAction="#handleSendAction" disable="true"/>
		<Button fx:id="btnRevised" text="Revised" onAction="#handleRevisedAction" disable="true"/>
		<Button fx:id="btnPayment" text="Payment" onAction="#handlePaymentAction" disable="true"/>
		<Button fx:id="btnRaiseCnDn" text="Raise CN/DN" onAction="#handleRaiseCnDnAction" disable="true"/>
		<Button fx:id="btnCancel" text="Cancel Invoice" onAction="#handleCancelAction" disable="true"/>
	</HBox>

	<!-- FILTER BAR -->
	<HBox spacing="12" alignment="CENTER_LEFT">

		<TextField fx:id="invoiceSearchField"
				   promptText="Invoice No..."
				   styleClass="search-field"
				   prefWidth="160"/>

		<ComboBox fx:id="clientComboBox"
				  promptText="Select Client..."
				  styleClass="combo-box-base"
				  prefWidth="240"/>

		<ComboBox fx:id="statusComboBox"
				  promptText="Status: All"
				  styleClass="combo-box-base"
				  prefWidth="160"/>

		<DatePicker fx:id="startDatePicker"
					promptText="From Date"
					styleClass="date-picker"
					prefWidth="160"/>

		<DatePicker fx:id="endDatePicker"
					promptText="To Date"
					styleClass="date-picker"
					prefWidth="160"/>

		<Button text="Search" fx:id="searchBtn" styleClass="search-button" onAction="#handleSearch"/>
		<Button text="Clear Filters" fx:id="clearBtn" styleClass="search-button" onAction="#handleClear"/>
	</HBox>

	<!-- TABLE CARD -->
	<VBox styleClass="table-card" VBox.vgrow="ALWAYS">
		<TableView fx:id="invoiceTable" styleClass="history-table" VBox.vgrow="ALWAYS">
			<columns>
				<TableColumn fx:id="colInvoiceNo" text="Invoice No" prefWidth="250" />
				<TableColumn fx:id="colClientName" text="Client Name" prefWidth="250" />
				<TableColumn fx:id="colInvoiceDate" text="Date" prefWidth="100" />
				<TableColumn fx:id="colAmount" text="Amount (₹)" prefWidth="120" />
				<TableColumn fx:id="colAdjustment" text="Adjustment" prefWidth="200" />
				<TableColumn fx:id="colPaid" text="Paid (₹)" prefWidth="120" />
				<TableColumn fx:id="colDue" text="Due (₹)" prefWidth="120" />
				<TableColumn fx:id="colStatus" text="Status" prefWidth="180" />
				<TableColumn fx:id="colPaymentStatus" text="Payment Status" prefWidth="180" />
				<TableColumn fx:id="colType" text="Type" prefWidth="120" />
			</columns>
		</TableView>
	</VBox>
</VBox>
