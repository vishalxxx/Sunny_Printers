<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.chart.PieChart?>

<ScrollPane xmlns="http://javafx.com/javafx/23" 
            xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true" 
            styleClass="main-scroll-pane, view-invoices-root"
            stylesheets="@../css/theme.css, @../css/view_invoices.css"
            fx:controller="controller.ViewInvoicesController">

    <VBox spacing="14" styleClass="root-container, ui-compact, taste-root">
        <padding>
            <Insets top="8" right="16" bottom="20" left="16" />
        </padding>

        <!-- 1. HEADER SECTION -->
        <VBox spacing="2">
            <HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="8" />
            <VBox spacing="2" styleClass="page-header-container">
                <Label text="View Invoices" styleClass="page-heading" />
                <Label text="Monitor payment status and manage invoice history" styleClass="page-subheading" />
            </VBox>
        </VBox>

        <!-- 2. ACTION TOOLBAR -->
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="vi-toolbar-card, info-card-premium">
            <HBox spacing="8" styleClass="vi-action-bar">
                <Button fx:id="btnEdit" text="Edit" onAction="#handleEditAction" styleClass="vi-btn-premium, vi-btn-edit">
                    <graphic><Region styleClass="vi-icon-edit"/></graphic>
                </Button>
                <Button fx:id="btnFinalize" text="Finalize" onAction="#handleFinalizeAction" styleClass="vi-btn-premium, vi-btn-finalize">
                    <graphic><Region styleClass="vi-icon-finalize"/></graphic>
                </Button>
                <Button fx:id="btnSend" text="Send" onAction="#handleSendAction" styleClass="vi-btn-premium, vi-btn-send">
                    <graphic><Region styleClass="vi-icon-send"/></graphic>
                </Button>
                <Button fx:id="btnRevised" text="Revised" onAction="#handleRevisedAction" styleClass="vi-btn-premium, vi-btn-revised">
                    <graphic><Region styleClass="vi-icon-revised"/></graphic>
                </Button>
                <Button fx:id="btnPayment" text="Payment" onAction="#handlePaymentAction" styleClass="vi-btn-premium, vi-btn-payment">
                    <graphic><Region styleClass="vi-icon-payment"/></graphic>
                </Button>
                <Button fx:id="btnRaiseCnDn" text="Raise CN/DN" onAction="#handleRaiseCnDnAction" styleClass="vi-btn-premium, vi-btn-cndn">
                    <graphic><Region styleClass="vi-icon-document"/></graphic>
                </Button>
                <Button fx:id="btnCancel" text="Cancel Invoice" onAction="#handleCancelAction" styleClass="vi-btn-premium, vi-btn-cancel">
                    <graphic><Region styleClass="vi-icon-cancel"/></graphic>
                </Button>
            </HBox>
        </HBox>

        <!-- 3. FILTER BAR -->
        <HBox spacing="14" alignment="CENTER_LEFT" styleClass="vi-filter-bar, info-card-premium">
            <VBox spacing="4" minWidth="150">
                <Label text="Search Invoice" styleClass="filter-label-taste"/>
                <TextField fx:id="invoiceSearchField" promptText="Invoice No..." styleClass="taste-field" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="4" minWidth="160">
                <Label text="Client" styleClass="filter-label-taste"/>
                <ComboBox fx:id="clientComboBox" promptText="All Clients" styleClass="taste-combo" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="4" minWidth="140">
                <Label text="Invoice Status" styleClass="filter-label-taste"/>
                <ComboBox fx:id="statusComboBox" promptText="All" styleClass="taste-combo" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="4" minWidth="130">
                <Label text="From Date" styleClass="filter-label-taste"/>
                <DatePicker fx:id="startDatePicker" styleClass="taste-datepicker" maxWidth="Infinity" editable="false"/>
            </VBox>
            <VBox spacing="4" minWidth="130">
                <Label text="To Date" styleClass="filter-label-taste"/>
                <DatePicker fx:id="endDatePicker" styleClass="taste-datepicker" maxWidth="Infinity" editable="false"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- 4. MAIN SPLIT LAYOUT -->
        <HBox spacing="16" styleClass="vi-main-row" VBox.vgrow="ALWAYS">
            <!-- Left: Table Area -->
            <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="vi-left-stack">
                <VBox styleClass="content-card-premium, vi-table-shell" VBox.vgrow="ALWAYS">
                    <TableView fx:id="invoiceTable" styleClass="jobs-table-premium" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colInvoiceNo" text="Invoice No." prefWidth="100" />
                            <TableColumn fx:id="colClientName" text="Client Name" prefWidth="220" />
                            <TableColumn fx:id="colInvoiceDate" text="Invoice Date ↓" prefWidth="110" />
                            <TableColumn fx:id="colAmount" text="Base Amount" prefWidth="100" styleClass="col-amount" />
                            <TableColumn fx:id="colAdjustment" text="Adjustment" prefWidth="85" styleClass="col-amount" />
                            <TableColumn fx:id="colNetAmount" text="Net Total" prefWidth="100" styleClass="col-amount-bold" />
                            <TableColumn fx:id="colNetPaid" text="Net Paid" prefWidth="100" styleClass="col-amount-paid" />
                            <TableColumn fx:id="colDue" text="Due Amount" prefWidth="100" styleClass="col-amount-due" />
                            <TableColumn fx:id="colStatus" text="Status" prefWidth="100" styleClass="col-center" />
                            <TableColumn fx:id="colActions" text="Actions" prefWidth="70" styleClass="col-center" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                    
                    <!-- Pagination -->
                    <HBox styleClass="vi-pagination-bar-premium">
                        <Label fx:id="paginationInfoLabel" text="Showing 1 to 20 of 126 invoices" styleClass="vi-page-info-taste"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox alignment="CENTER" spacing="8">
                            <Button styleClass="vi-nav-btn" text="I‹" />
                            <Button styleClass="vi-nav-btn" text="‹" />
                            <HBox fx:id="paginationPagesBox" spacing="4" alignment="CENTER" styleClass="vi-page-nav-taste" />
                            <Button styleClass="vi-nav-btn" text="..."/>
                            <Button styleClass="vi-nav-btn" text="7" />
                            <Button styleClass="vi-nav-btn" text="›" />
                            <Button styleClass="vi-nav-btn" text="›I" />
                        </HBox>
                        <Region minWidth="20" />
                        <ComboBox fx:id="pageSizeCombo" styleClass="taste-combo-sm" prefWidth="100" promptText="20 / page" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Right: Sidebar -->
            <VBox spacing="14" styleClass="vi-sidebar" minWidth="300">
                <!-- Invoice Summary -->
                <VBox spacing="14" styleClass="info-card-premium, vi-side-card">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Region styleClass="vi-icon-summary"/>
                        <Label text="Invoice Summary" styleClass="vi-side-title-taste"/>
                    </HBox>
                    <VBox spacing="10" styleClass="vi-summary-list">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Invoices" styleClass="vi-summary-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="sumCountLabel" text="126" styleClass="vi-summary-value-bold"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Base Amount" styleClass="vi-summary-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="sumBaseLabel" text="₹ 1,25,680.00" styleClass="vi-summary-value-bold"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Adjustment" styleClass="vi-summary-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="sumAdjustmentLabel" text="₹ 0.00" styleClass="vi-summary-value-bold"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Net Amount" styleClass="vi-summary-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="sumNetLabel" text="₹ 1,25,680.00" styleClass="vi-summary-value-hero"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Paid Amount" styleClass="vi-summary-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="sumPaidLabel" text="₹ 45,600.00" styleClass="vi-summary-value-paid"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Due Amount" styleClass="vi-summary-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="sumDueLabel" text="₹ 80,080.00" styleClass="vi-summary-value-due"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Status Overview Chart -->
                <VBox spacing="10" styleClass="info-card-premium, vi-side-card" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Region styleClass="vi-icon-chart"/>
                        <Label text="Status Overview" styleClass="vi-side-title-taste"/>
                    </HBox>
                    <PieChart fx:id="statusPieChart" styleClass="vi-donut-chart" legendSide="RIGHT" />
                </VBox>

                <!-- Quick Filters -->

            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
