<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.PaymentHistoryController"
            stylesheets="@../css/theme.css, @../css/payment_history.css"
            styleClass="payment-history-root">

    <center>
        <ScrollPane fitToWidth="true" styleClass="ph-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
            <content>
                <VBox spacing="16" alignment="TOP_LEFT" styleClass="ph-page, ui-compact, app-page-shell" fillWidth="true">

                    <HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="8"/>

                    <!-- Filters: two cards (client/invoice/dates | search/reset) -->
                    <HBox spacing="16" alignment="TOP_LEFT">
                        <VBox spacing="16" styleClass="info-card-premium, ph-card" HBox.hgrow="ALWAYS">
                            <VBox spacing="8">
                                <Label text="SELECT CLIENT" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="clientCombo" promptText="Select Client" prefWidth="0" maxWidth="Infinity"
                                          styleClass="taste-combo" editable="false"/>
                            </VBox>
                            <VBox spacing="8">
                                <Label text="SELECT INVOICE" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="invoiceCombo" promptText="Select invoice..." prefWidth="0" maxWidth="Infinity"
                                          styleClass="taste-combo"/>
                            </VBox>
                            <GridPane hgap="16" vgap="16">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                </columnConstraints>
                                <VBox spacing="8" GridPane.columnIndex="0">
                                    <Label text="FROM DATE" styleClass="field-heading-sm"/>
                                    <DatePicker fx:id="fromDate" promptText="mm/dd/yy" prefWidth="0" maxWidth="Infinity"
                                                styleClass="taste-datepicker" editable="false"/>
                                </VBox>
                                <VBox spacing="8" GridPane.columnIndex="1">
                                    <Label text="TO DATE" styleClass="field-heading-sm"/>
                                    <DatePicker fx:id="toDate" promptText="mm/dd/yy" prefWidth="0" maxWidth="Infinity"
                                                styleClass="taste-datepicker" editable="false"/>
                                </VBox>
                            </GridPane>
                        </VBox>

                        <VBox spacing="16" styleClass="info-card-premium, ph-card" HBox.hgrow="ALWAYS" minWidth="280">
                            <VBox styleClass="kpi-card, kpi-card-green" minWidth="0" maxWidth="Infinity" spacing="6"
                                  alignment="CENTER_LEFT">
                                <Label text="TOTAL RECEIVED" styleClass="kpi-label"/>
                                <Label fx:id="totalAmountLabel" text="₹0.00" styleClass="kpi-value-green"/>
                            </VBox>
                            <VBox spacing="8" VBox.vgrow="ALWAYS">
                                <Label text="SEARCH PAYMENTS" styleClass="field-heading-sm"/>
                                <TextField fx:id="searchField" promptText="Search amount, ref, method..."
                                           styleClass="taste-field"/>
                            </VBox>
                            <Region minHeight="8"/>
                            <HBox spacing="12" alignment="BOTTOM_RIGHT">
                                <Button text="Reset Filters" styleClass="ph-btn, ph-btn-outline" onAction="#onReset"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Table -->
                    <VBox spacing="0" styleClass="content-card-premium, ph-table-shell" VBox.vgrow="ALWAYS" minHeight="320">
                        <HBox styleClass="ph-table-toolbar" alignment="CENTER_LEFT" spacing="12">
                            <padding>
                                <Insets top="14" right="16" bottom="14" left="16"/>
                            </padding>
                            <Label text="PAYMENT RECORDS" styleClass="card-title-sm"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Filtered view" styleClass="ph-filter-pill"/>
                        </HBox>

                        <TableView fx:id="paymentsTable" VBox.vgrow="ALWAYS" minHeight="280" styleClass="ph-payments-table"
                                   style="-fx-pref-height: 400px;">
                            <columns>
                                <TableColumn fx:id="colDate" text="DATE" prefWidth="120"/>
                                <TableColumn fx:id="colClient" text="CLIENT NAME" prefWidth="250"/>
                                <TableColumn fx:id="colType" text="TYPE" prefWidth="100"/>
                                <TableColumn fx:id="colInvoiceRef" text="REFERENCES" prefWidth="220"/>
                                <TableColumn fx:id="colMethod" text="METHOD" prefWidth="120"/>
                                <TableColumn fx:id="colAmount" text="AMOUNT (₹)" prefWidth="140"
                                             style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
                                <TableColumn fx:id="colReference" text="BANKING DETAILS / UTR" prefWidth="300"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                            <placeholder>
                                <Label text="No payments found matching criteria" styleClass="ph-placeholder"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
