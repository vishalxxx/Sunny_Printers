<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/23"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="controller.ViewInvoiceJobsController" spacing="20"
	stylesheets="@../css/view_job.css" >

	<Label fx:id="lblPageHeading" text="View Invoice Jobs" styleClass="page-heading" />

	<HBox fx:id="searchModeBox" spacing="12" alignment="CENTER_LEFT" styleClass="search-bar">
        <ComboBox fx:id="clientComboBox"
                  promptText="Select Client..."
                  styleClass="combo-box-base"
                  prefWidth="300"/>

        <ComboBox fx:id="invoiceComboBox"
                  promptText="Select Invoice..."
                  styleClass="combo-box-base"
                  prefWidth="250"
                  disable="true"/>
	</HBox>

	<VBox fx:id="editModeBox" managed="false" visible="false" spacing="15" styleClass="card" style="-fx-background-color: #141414; -fx-padding: 15; -fx-border-color: #27272a; -fx-border-radius: 8; -fx-background-radius: 8;">
        <HBox spacing="20" alignment="CENTER_LEFT">
            <VBox spacing="5" prefWidth="280">
                <Label text="CLIENT NAME" style="-fx-text-fill: #a1a1aa; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                <TextField fx:id="txtClientName" editable="false" styleClass="text-field" style="-fx-font-size: 13px; -fx-background-color: #09090b; -fx-border-color: #27272a;" />
            </VBox>
            <VBox spacing="5" prefWidth="130">
                <Label text="INVOICE NO" style="-fx-text-fill: #a1a1aa; -fx-font-size: 10px; -fx-font-weight: bold;" />
                <TextField fx:id="txtInvoiceNo" editable="false" styleClass="text-field" style="-fx-font-size: 13px; -fx-background-color: #09090b; -fx-border-color: #27272a;" />
            </VBox>
            <VBox spacing="5" prefWidth="130">
                <Label text="INVOICE DATE" style="-fx-text-fill: #a1a1aa; -fx-font-size: 10px; -fx-font-weight: bold;" />
                <DatePicker fx:id="dpInvoiceDate" prefWidth="130" styleClass="date-picker" />
            </VBox>
            <VBox spacing="5" prefWidth="130">
                <Label text="PROCESS STATUS" style="-fx-text-fill: #a1a1aa; -fx-font-size: 10px; -fx-font-weight: bold;" />
                <TextField fx:id="txtProcessStatus" editable="false" styleClass="text-field" style="-fx-font-size: 13px; -fx-background-color: #09090b; -fx-border-color: #27272a;" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <VBox spacing="8" alignment="CENTER_RIGHT">
                <Button fx:id="btnSave" text="Save Changes" onAction="#handleSaveChanges" prefWidth="130" styleClass="btn-primary" />
                <Button fx:id="btnDiscard" text="Discard" onAction="#handleDiscardChanges" prefWidth="130" style="-fx-background-color: #27272a; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-cursor: hand;" />
            </VBox>
        </HBox>
	</VBox>

    <Label fx:id="resultLabel" text="Showing 0 jobs" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />

	<!-- JOB ACTIONS -->
	<HBox fx:id="jobActionsBox" spacing="10" alignment="CENTER_LEFT" styleClass="action-bar" managed="false" visible="false">
		<Button fx:id="btnJobView" text="View" onAction="#handleJobViewAction" disable="true" />
		<Button fx:id="btnJobEdit" text="Edit" onAction="#handleJobEditAction" disable="true" />
		<Button fx:id="btnJobCancel" text="Cancel Job" onAction="#handleJobCancelAction" disable="true" />
		<Button fx:id="btnJobUnlink" text="Unlink Job" onAction="#handleJobUnlinkAction" disable="true" />
		<Region HBox.hgrow="ALWAYS" />
		<Button fx:id="btnAddJob" text="Add Jobs" onAction="#handleAddJobsToInvoice" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" />
	</HBox>

	<VBox styleClass="table-card" VBox.vgrow="ALWAYS">
		<TableView fx:id="jobsTable" styleClass="history-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="70" />
                <TableColumn fx:id="jobNoCol" text="Job No" prefWidth="140" />
                <TableColumn fx:id="titleCol" text="Job Title" prefWidth="240" />
                <TableColumn fx:id="dateCol" text="Job Date" prefWidth="120" />
                <TableColumn fx:id="jobTotalCol" text="Job Total" prefWidth="120" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120" />
                <TableColumn fx:id="remarksCol" text="Remarks" prefWidth="220" />
            </columns>
        </TableView>
	</VBox>
</VBox>
