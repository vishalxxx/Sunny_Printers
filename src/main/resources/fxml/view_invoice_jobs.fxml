<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/23"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="controller.ViewInvoiceJobsController" spacing="8"
	alignment="TOP_LEFT" fillWidth="true"
	styleClass="view-invoice-jobs-root, ui-compact, app-page-shell"
	stylesheets="@../css/theme.css, @../css/view_job.css" >

    <VBox spacing="4" styleClass="app-page-title-block page-header-container">
		<Label fx:id="lblPageHeading" text="View Invoice Jobs" styleClass="page-heading" />
	</VBox>
	<HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 0 5 0;"/>

    <!-- Search Mode: Initial Selection -->
    <HBox fx:id="searchModeBox" spacing="12" alignment="CENTER_LEFT" styleClass="header-bar" style="-fx-padding: 12 14;">
        <VBox spacing="6">
            <Label text="SELECT CLIENT" styleClass="compact-field-label"/>
            <ComboBox fx:id="clientComboBox" promptText="Select Client" styleClass="taste-combo" prefWidth="320" />
        </VBox>
        <VBox spacing="6">
            <Label text="INVOICE NO" styleClass="compact-field-label"/>
            <ComboBox fx:id="invoiceComboBox" promptText="Select Invoice..." styleClass="taste-combo" prefWidth="250" disable="true"/>
        </VBox>
    </HBox>

    <!-- Edit Mode: Details after selection -->
    <VBox fx:id="editModeBox" styleClass="header-bar" spacing="12" managed="false" visible="false">
        <padding>
            <Insets top="12" right="14" bottom="12" left="14" />
        </padding>
        
        <HBox spacing="12" alignment="CENTER_LEFT">
            <VBox spacing="6">
                <Label text="CLIENT NAME" styleClass="compact-field-label"/>
                <TextField fx:id="txtClientName" editable="false" styleClass="taste-field" prefWidth="320" />
            </VBox>
            
            <VBox spacing="6">
                <Label text="INVOICE NO" styleClass="compact-field-label"/>
                <TextField fx:id="txtInvoiceNo" editable="false" styleClass="taste-field" prefWidth="200" />
            </VBox>
            
            <VBox spacing="6">
                <Label text="INVOICE DATE" styleClass="compact-field-label"/>
                <DatePicker fx:id="dpInvoiceDate" promptText="Select Date" styleClass="taste-datepicker" prefWidth="160"/>
            </VBox>
            
            <VBox spacing="6">
                <Label text="PROCESS STATUS" styleClass="compact-field-label"/>
                <TextField fx:id="txtProcessStatus" editable="false" styleClass="compact-job-no" prefWidth="180" alignment="CENTER_LEFT" style="-fx-text-fill: #FA8C16; -fx-background-color: #FFF2E8; -fx-border-color: #FFE7BA;" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />
            
            <!-- Dynamic Save/Discard Box -->
            <VBox fx:id="saveDiscardBox" spacing="8" alignment="CENTER_RIGHT">
                <Button fx:id="btnSave" text="Save Changes  ✓" onAction="#handleSaveChanges" styleClass="finish-btn-premium" prefWidth="140" />
                <Button fx:id="btnDiscard" text="✕  Discard" onAction="#handleDiscardChanges" styleClass="cancel-btn" />
            </VBox>
        </HBox>
    </VBox>

    <Label fx:id="resultLabel" text="Showing 1 jobs" style="-fx-font-size: 14px; -fx-font-weight: 800; -fx-text-fill: #A39890;" />

	<!-- JOB ACTIONS -->
	<HBox fx:id="jobActionsBox" spacing="12" alignment="CENTER_LEFT" styleClass="action-bar" managed="false" visible="false" style="-fx-padding: 10 0;">
		<Button fx:id="btnJobView" text="View" onAction="#handleJobViewAction" disable="true" styleClass="action-btn-premium">
            <graphic>
                <Region style="-fx-shape: 'M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z'; -fx-background-color: white; -fx-min-width: 14; -fx-min-height: 14;" />
            </graphic>
        </Button>
		<Button fx:id="btnJobEdit" text="Edit" onAction="#handleJobEditAction" disable="true" styleClass="action-btn-premium" style="-fx-background-color: #FFAA00;">
            <graphic>
                <Region style="-fx-shape: 'M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z'; -fx-background-color: white; -fx-min-width: 14; -fx-min-height: 14;" />
            </graphic>
        </Button>
		<Button fx:id="btnJobCancel" text="Cancel Job" onAction="#handleJobCancelAction" disable="true" styleClass="action-btn-premium" style="-fx-background-color: #EF476F;">
            <graphic>
                <Region style="-fx-shape: 'M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z'; -fx-background-color: white; -fx-min-width: 14; -fx-min-height: 14;" />
            </graphic>
        </Button>
		<Button fx:id="btnJobUnlink" text="Unlink Job" onAction="#handleJobUnlinkAction" disable="true" styleClass="action-btn-premium" style="-fx-background-color: #9D4EDD;">
            <graphic>
                <Region style="-fx-shape: 'M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z'; -fx-background-color: white; -fx-min-width: 14; -fx-min-height: 14;" />
            </graphic>
        </Button>
		<Region HBox.hgrow="ALWAYS" />
		<Button fx:id="btnAddJob" text="Add Jobs  +" onAction="#handleAddJobsToInvoice" styleClass="add-item-btn" />
	</HBox>

	<StackPane VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #EEECE8; -fx-border-width: 1.5; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(62, 49, 45, 0.05), 20, 0, 0, 5);">
		<TableView fx:id="jobsTable" styleClass="invoice-jobs-table-premium" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="selectCol" text="" prefWidth="50" sortable="false" />
                <TableColumn fx:id="idCol" text="ID" prefWidth="60" />
                <TableColumn fx:id="jobNoCol" text="Job No" prefWidth="120" />
                <TableColumn fx:id="titleCol" text="Job Title" prefWidth="240" />
                <TableColumn fx:id="dateCol" text="Job Date" prefWidth="120" />
                <TableColumn fx:id="jobTotalCol" text="Job Total" prefWidth="140" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="160" />
                <TableColumn fx:id="remarksCol" text="Remarks" prefWidth="160" />
                <TableColumn fx:id="actionsCol" text="Actions" prefWidth="140" sortable="false" />
            </columns>
        </TableView>
	</StackPane>
</VBox>
