<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/23"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controller.ViewInvoiceJobsController" spacing="8"
    alignment="TOP_LEFT" fillWidth="true"
    styleClass="view-invoice-jobs-root, ui-compact, app-page-shell"
    stylesheets="@../css/theme.css, @../css/view_job.css,@../css/add_job.css">


    <HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" alignment="CENTER_LEFT"
        spacing="8" style="-fx-padding: 0 0 10 0;" />

    <!-- Search Mode: Initial Selection -->
    <HBox fx:id="searchModeBox" spacing="16" alignment="CENTER_LEFT"
        styleClass="invoice-card-container" style="-fx-padding: 10 16;">
        <VBox spacing="6">
            <Label text="SELECT CLIENT" styleClass="field-heading-sm" />
            <ComboBox fx:id="clientComboBox" promptText="Select Client" styleClass="taste-combo"
                prefWidth="320" editable="false" />
        </VBox>
        <VBox spacing="6">
            <Label text="INVOICE NO" styleClass="field-heading-sm" />
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Region fx:id="invoiceIconSearch"
                    style="-fx-shape: 'M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z'; -fx-background-color: #CD7B4E; -fx-min-width: 16; -fx-min-height: 16;" />
                <ComboBox fx:id="invoiceComboBox" promptText="Select Invoice..." styleClass="taste-combo"
                    prefWidth="250" editable="false" />
            </HBox>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- Edit Mode: Details after selection -->
    <VBox fx:id="editModeBox" styleClass="invoice-card-container" spacing="12" managed="false"
        visible="false">
        <padding>
            <Insets top="16" right="20" bottom="16" left="20" />
        </padding>

        <HBox spacing="16" alignment="CENTER_LEFT">
            <VBox spacing="6">
                <Label text="CLIENT NAME" styleClass="field-heading-sm" />
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="details-field-container">
                    <Region
                        style="-fx-shape: 'M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z'; -fx-background-color: #4285F4; -fx-min-width: 16; -fx-min-height: 16;" />
                    <ComboBox fx:id="txtClientName" styleClass="transparent-combo, client-name-combo" prefWidth="320"
                        editable="false" />
                </HBox>
            </VBox>

            <VBox spacing="6">
                <Label text="INVOICE NO" styleClass="field-heading-sm" />
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="details-field-container">
                    <Region fx:id="invoiceIconEdit"
                        style="-fx-shape: 'M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z'; -fx-background-color: #CD7B4E; -fx-min-width: 16; -fx-min-height: 16;" />
                    <ComboBox fx:id="txtInvoiceNo" styleClass="transparent-combo, invoice-no-combo" prefWidth="250"
                        editable="false" />
                </HBox>
            </VBox>

            <VBox spacing="6">
                <Label text="INVOICE DATE" styleClass="field-heading-sm" />
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="details-field-container">
                    <DatePicker fx:id="dpInvoiceDate" promptText="Select Date"
                        styleClass="transparent-datepicker" prefWidth="120" disable="true" />
                </HBox>
            </VBox>

            <VBox spacing="6">
                <Label text="PROCESS STATUS" styleClass="field-heading-sm" />
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="details-field-container"
                    style="-fx-background-color: #FFF2E8;">
                    <Region
                        style="-fx-background-color: #FA8C16; -fx-background-radius: 50%; -fx-min-width: 8; -fx-min-height: 8; -fx-max-width: 8; -fx-max-height: 8;" />
                    <TextField fx:id="txtProcessStatus" editable="false"
                        styleClass="transparent-textfield" prefWidth="80" alignment="CENTER_LEFT"
                        style="-fx-text-fill: #FA8C16; -fx-font-weight: 800;" />
                </HBox>
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <Region style="-fx-background-color: #F1ECE6; -fx-min-width: 1.5; -fx-max-width: 1.5;" />

            <StackPane style="-fx-padding: 0 10 0 25;">
                <Region
                    style="-fx-shape: 'M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z'; -fx-background-color: #F1ECE6; -fx-min-width: 32; -fx-min-height: 32;" />
            </StackPane>

            <!-- Dynamic Save/Discard Box (Hidden by default but keep references) -->
            <VBox fx:id="saveDiscardBox" spacing="8" alignment="CENTER_RIGHT" managed="false"
                visible="false">
                <Button fx:id="btnSave" text="Save Changes  ✓" onAction="#handleSaveChanges"
                    styleClass="finish-btn-premium" prefWidth="140" />
                <Button fx:id="btnDiscard" text="✕  Discard" onAction="#handleDiscardChanges"
                    styleClass="cancel-btn" />
            </VBox>
        </HBox>
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label fx:id="resultLabel" text="Showing 1 jobs"
            style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #8E7B71;" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- JOB ACTIONS -->
    <HBox fx:id="jobActionsBox" spacing="10" alignment="CENTER_LEFT" styleClass="action-bar"
        managed="false" visible="false" style="-fx-padding: 4 0 8 0;">
        <Button fx:id="btnJobView" text="View" onAction="#handleJobViewAction" disable="true"
            styleClass="action-btn-custom, btn-cyan">
            <graphic>
                <Region
                    style="-fx-shape: 'M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z'; -fx-background-color: white; -fx-min-width: 14; -fx-min-height: 14;" />
            </graphic>
        </Button>
        <Button fx:id="btnJobEdit" text="Edit" onAction="#handleJobEditAction" disable="true"
            styleClass="action-btn-custom, btn-orange">
            <graphic>
                <Region
                    style="-fx-shape: 'M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z'; -fx-background-color: white; -fx-min-width: 14; -fx-min-height: 14;" />
            </graphic>
        </Button>
        <Button fx:id="btnJobCancel" text="Cancel Job" onAction="#handleJobCancelAction"
            disable="true" styleClass="action-btn-custom, btn-red">
            <graphic>
                <Region
                    style="-fx-shape: 'M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z'; -fx-background-color: white; -fx-min-width: 14; -fx-min-height: 14;" />
            </graphic>
        </Button>
        <Button fx:id="btnJobUnlink" text="Unlink Job" onAction="#handleJobUnlinkAction"
            disable="true" styleClass="action-btn-custom, btn-purple">
            <graphic>
                <Region
                    style="-fx-shape: 'M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z'; -fx-background-color: white; -fx-min-width: 14; -fx-min-height: 14;" />
            </graphic>
        </Button>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnAddJob" text="+ Add Jobs" onAction="#handleAddJobsToInvoice"
            styleClass="action-btn-custom, btn-light-green" />
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="invoice-card-container" spacing="12" style="-fx-padding: 14;">
        <TableView fx:id="jobsTable" styleClass="invoice-jobs-table-premium" VBox.vgrow="ALWAYS" style="-fx-margin: 0 0 0 4;">
            <columns>
                <TableColumn fx:id="selectCol" text="" prefWidth="40" sortable="false" />
                <TableColumn fx:id="idCol" text="ID" prefWidth="65" />
                <TableColumn fx:id="jobNoCol" text="Job No" prefWidth="100" />
                <TableColumn fx:id="titleCol" text="Job Title" prefWidth="280" />
                <TableColumn fx:id="dateCol" text="Job Date" prefWidth="120" />
                <TableColumn fx:id="jobTotalCol" text="Job Total" prefWidth="135" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="165" />
                <TableColumn fx:id="remarksCol" text="Remarks" prefWidth="100" />
                <TableColumn fx:id="actionsCol" text="Actions" prefWidth="120" sortable="false" />
            </columns>
        </TableView>

        <!-- TABLE FOOTER / PAGINATION -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 4 10 4;">
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="Showing" styleClass="footer-text" />
                <Label fx:id="paginationInfoLabel" text="0 of 0" styleClass="footer-text" />
                <Label text="premium jobs." styleClass="footer-text" />
                <Label text="Download full PDF directory" styleClass="footer-link"
                    style="-fx-cursor: hand;" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox fx:id="paginationContainer" spacing="8" alignment="CENTER">
                <Button text="&lt;" styleClass="page-btn" />
                <Button text="1" styleClass="page-btn, page-btn-active" />
                <Button text="&gt;" styleClass="page-btn" />
                
                <Label text="Go to:" style="-fx-text-fill: #A79F99; -fx-font-size: 11px; -fx-padding: 0 0 0 10;" />
                <TextField fx:id="txtGotoPage" styleClass="goto-page-field" />
            </HBox>
        </HBox>
    </VBox>
</VBox>