<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<ScrollPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.GenerateGSTInvoiceController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="gst-scroll-root, ui-compact, app-page-shell"
            stylesheets="@../css/theme.css, @../css/view_job.css, @../css/view_client.css, @../css/genrate_gst_invoice.css">

    <VBox spacing="18" styleClass="gst-root">
        <padding>
            <Insets top="8" right="6" bottom="18" left="6"/>
        </padding>

        <!-- Breadcrumbs below dashboard title (same as view_job.fxml) -->
        <HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="8" />

        <!-- ===== Top Actions ===== -->
        <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 0 0 6 0;">
            <VBox.margin>
                <Insets top="-10"/>
            </VBox.margin>
            <Button fx:id="btnSaveDraft" onAction="#handleSaveDraft" text="Save Draft" styleClass="action-btn-custom, btn-light-orange" prefWidth="120"/>
            <Button fx:id="btnGenerateInvoice" onAction="#handleGenerateInvoice" text="Generate Invoice" styleClass="action-btn-custom, btn-terracotta" prefWidth="150"/>
        </HBox>

        <!-- ===== Invoice Details ===== -->
        <VBox spacing="10" styleClass="gst-card">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Region styleClass="gst-card-icon, icon-invoice-details"/>
                <Label text="Invoice Details" styleClass="gst-card-title"/>
            </HBox>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="10.0" fillWidth="true" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="10.0" fillWidth="true" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="10.0" fillWidth="true" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="10.0" fillWidth="true" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="10.0" fillWidth="true" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="10.0" fillWidth="true" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="10.0" fillWidth="true" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="10.0" fillWidth="true" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="10.0" fillWidth="true" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="10.0" fillWidth="true" hgrow="ALWAYS"/>
                </columnConstraints>

                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2" GridPane.hgrow="ALWAYS">
                    <Label text="Invoice No." styleClass="gst-label-xs"/>
                    <TextField fx:id="txtInvoiceNo" text="355" editable="false" styleClass="compact-field, gst-input" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.columnSpan="2" GridPane.hgrow="ALWAYS">
                    <Label text="Invoice Date" styleClass="gst-label-xs"/>
                    <DatePicker fx:id="dpInvoiceDate" styleClass="compact-datepicker, gst-input" editable="false" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="4" GridPane.rowIndex="0" GridPane.columnSpan="2" GridPane.hgrow="ALWAYS">
                    <Label text="Place of Supply" styleClass="gst-label-xs"/>
                    <ComboBox fx:id="comboPlaceOfSupply" promptText="Select state" styleClass="card-combo, gst-input" maxWidth="Infinity">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Jammu &amp; Kashmir (01)"/>
                                <String fx:value="Himachal Pradesh (02)"/>
                                <String fx:value="Punjab (03)"/>
                                <String fx:value="Chandigarh (04)"/>
                                <String fx:value="Uttarakhand (05)"/>
                                <String fx:value="Haryana (06)"/>
                                <String fx:value="Delhi (07)"/>
                                <String fx:value="Rajasthan (08)"/>
                                <String fx:value="Uttar Pradesh (09)"/>
                                <String fx:value="Bihar (10)"/>
                                <String fx:value="Sikkim (11)"/>
                                <String fx:value="Arunachal Pradesh (12)"/>
                                <String fx:value="Nagaland (13)"/>
                                <String fx:value="Manipur (14)"/>
                                <String fx:value="Mizoram (15)"/>
                                <String fx:value="Tripura (16)"/>
                                <String fx:value="Meghalaya (17)"/>
                                <String fx:value="Assam (18)"/>
                                <String fx:value="West Bengal (19)"/>
                                <String fx:value="Jharkhand (20)"/>
                                <String fx:value="Odisha (21)"/>
                                <String fx:value="Chhattisgarh (22)"/>
                                <String fx:value="Madhya Pradesh (23)"/>
                                <String fx:value="Gujarat (24)"/>
                                <String fx:value="Daman &amp; Diu (25)"/>
                                <String fx:value="Dadra &amp; Nagar Haveli (26)"/>
                                <String fx:value="Maharashtra (27)"/>
                                <String fx:value="Andhra Pradesh (28)"/>
                                <String fx:value="Karnataka (29)"/>
                                <String fx:value="Goa (30)"/>
                                <String fx:value="Lakshadweep (31)"/>
                                <String fx:value="Kerala (32)"/>
                                <String fx:value="Tamil Nadu (33)"/>
                                <String fx:value="Puducherry (34)"/>
                                <String fx:value="Andaman &amp; Nicobar Islands (35)"/>
                                <String fx:value="Telangana (36)"/>
                                <String fx:value="Andhra Pradesh (New) (37)"/>
                                <String fx:value="Ladakh (38)"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="6" GridPane.rowIndex="0" GridPane.columnSpan="2" GridPane.hgrow="ALWAYS">
                    <Label text="Payment Terms" styleClass="gst-label-xs"/>
                    <ComboBox fx:id="comboPaymentTerms" promptText="30 Days" styleClass="card-combo, gst-input" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="8" GridPane.rowIndex="0" GridPane.columnSpan="2" GridPane.hgrow="ALWAYS">
                    <Label text="Due Date" styleClass="gst-label-xs"/>
                    <DatePicker fx:id="dpDueDate" styleClass="compact-datepicker, gst-input" editable="false" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="5" GridPane.hgrow="ALWAYS">
                    <Label text="Vehicle / Dispatch" styleClass="gst-label-xs"/>
                    <TextField fx:id="txtVehicleDispatch" promptText="Transport" styleClass="compact-field, gst-input" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="5" GridPane.rowIndex="1" GridPane.columnSpan="5" GridPane.hgrow="ALWAYS">
                    <Label text="Reference / PO No." styleClass="gst-label-xs"/>
                    <TextField fx:id="txtPoNo" promptText="PO/..." styleClass="compact-field, gst-input" maxWidth="Infinity"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- ===== Companies Row ===== -->
        <GridPane hgap="12">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" fillWidth="true"/>
                <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" fillWidth="true"/>
                <ColumnConstraints percentWidth="33.34" hgrow="ALWAYS" fillWidth="true"/>
            </columnConstraints>

            <!-- Company (From) -->
            <VBox spacing="10" styleClass="gst-card" GridPane.columnIndex="0" maxWidth="Infinity">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="gst-card-icon, icon-company"/>
                    <Label text="Company (From)" styleClass="gst-card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Manage Companies" styleClass="gst-mini-btn"/>
                </HBox>
                <ComboBox fx:id="comboCompanyFrom" promptText="SUNNY PRINTER (2026-27)" styleClass="card-combo" maxWidth="Infinity"/>
                <VBox spacing="10" styleClass="gst-address-block">
                    <Label fx:id="lblCompanyAddress" wrapText="true" styleClass="gst-address-text"/>
                    <HBox spacing="12">
                        <VBox spacing="4" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="GSTIN/UIN" styleClass="gst-address-label"/>
                            <Label fx:id="lblCompanyGstin" wrapText="true" styleClass="gst-address-value"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="State" styleClass="gst-address-label"/>
                            <Label fx:id="lblCompanyState" wrapText="true" styleClass="gst-address-value"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Email" styleClass="gst-address-label"/>
                            <Label fx:id="lblCompanyEmail" wrapText="true" styleClass="gst-address-value"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Ship To (Consignee) -->
            <VBox spacing="10" styleClass="gst-card" GridPane.columnIndex="1" maxWidth="Infinity">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="gst-card-icon, icon-user"/>
                    <Label text="Ship To (Consignee)" styleClass="gst-card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ New" styleClass="gst-mini-btn"/>
                </HBox>
                <ComboBox fx:id="comboShipTo" promptText="Select consignee" styleClass="card-combo" maxWidth="Infinity"/>
                <VBox spacing="8" styleClass="gst-address-block">
                    <Label fx:id="lblShipToAddress" wrapText="true" styleClass="gst-address-text"/>
                    <HBox spacing="20">
                        <VBox spacing="2">
                            <Label text="GSTIN/UIN" styleClass="gst-address-label"/>
                            <Label fx:id="lblShipToGstin" styleClass="gst-address-value"/>
                        </VBox>
                        <VBox spacing="2">
                            <Label text="State" styleClass="gst-address-label"/>
                            <Label fx:id="lblShipToState" styleClass="gst-address-value"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Bill To (Buyer) -->
            <VBox spacing="10" styleClass="gst-card" GridPane.columnIndex="2" maxWidth="Infinity">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="gst-card-icon, icon-user"/>
                    <Label text="Bill To (Buyer)" styleClass="gst-card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ New" styleClass="gst-mini-btn"/>
                </HBox>
                <ComboBox fx:id="comboBillTo" promptText="Select buyer" styleClass="card-combo" maxWidth="Infinity"/>
                <VBox spacing="8" styleClass="gst-address-block">
                    <Label fx:id="lblBillToAddress" wrapText="true" styleClass="gst-address-text"/>
                    <HBox spacing="20">
                        <VBox spacing="2">
                            <Label text="GSTIN/UIN" styleClass="gst-address-label"/>
                            <Label fx:id="lblBillToGstin" styleClass="gst-address-value"/>
                        </VBox>
                        <VBox spacing="2">
                            <Label text="State" styleClass="gst-address-label"/>
                            <Label fx:id="lblBillToState" styleClass="gst-address-value"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </GridPane>

        <!-- ===== Jobs strip + Summary ===== -->
        <HBox spacing="12" alignment="TOP_LEFT">
            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="gst-card">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="gst-card-icon, icon-jobs"/>
                    <Label text="Select Job (Optional)" styleClass="gst-card-title"/>
                    <StackPane HBox.hgrow="ALWAYS" styleClass="gst-search-wrap">
                        <TextField promptText="Search job by name or job no..." styleClass="gst-search-field" HBox.hgrow="ALWAYS"/>
                        <Region styleClass="gst-search-glyph" mouseTransparent="true" StackPane.alignment="CENTER_LEFT"/>
                    </StackPane>
                    <Button text="View All Jobs" styleClass="gst-link-btn"/>
                </HBox>

                <FlowPane fx:id="flowJobsContainer" hgap="10" vgap="10" styleClass="gst-job-chip-row">
                    <!-- Dynamic jobs will be loaded here by controller -->
                </FlowPane>
            </VBox>

            <VBox spacing="12" prefWidth="300" minWidth="250" styleClass="gst-card">
                <Label text="Invoice Summary" styleClass="gst-card-title"/>

                <VBox spacing="10" styleClass="gst-summary-block">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Total Items" styleClass="gst-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblTotalItems" text="1" styleClass="gst-strong"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Total Quantity" styleClass="gst-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblTotalQty" text="0 PCS" styleClass="gst-strong"/>
                    </HBox>
                </VBox>

                <Separator styleClass="gst-sep"/>

                <VBox spacing="10">
                    <Label text="Amount Summary" styleClass="gst-subtitle"/>
                    <VBox spacing="8">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Taxable Value" styleClass="gst-muted"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblTaxable" text="₹ 0.00" styleClass="gst-strong"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="CGST (₹)" styleClass="gst-muted"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblCgst" text="—" styleClass="gst-strong"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="SGST (₹)" styleClass="gst-muted"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblSgst" text="—" styleClass="gst-strong"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="IGST (₹)" styleClass="gst-muted"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblIgst" text="—" styleClass="gst-strong"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Round Off" styleClass="gst-muted"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblRoundOff" text="₹ 0.00" styleClass="gst-strong"/>
                        </HBox>
                    </VBox>
                </VBox>

                <VBox spacing="6" styleClass="gst-grand-total">
                    <Label text="Grand Total" styleClass="gst-muted"/>
                    <Label fx:id="lblGrandTotal" text="₹ 0.00" styleClass="gst-grand-amount"/>
                    <Label fx:id="lblGrandTotalWords" text="" wrapText="true" styleClass="gst-grand-words"/>
                </VBox>
            </VBox>
        </HBox>

        <!-- ===== Line items table area + lower cards ===== -->
        <VBox spacing="12" styleClass="gst-card">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <Region HBox.hgrow="ALWAYS"/>
                <MenuButton fx:id="btnAddItem" text="+ Add Item" styleClass="gst-btn-chip">
                    <items>
                        <MenuItem text="FREIGHT OUTWARD CHARGES" onAction="#handleFreightOutward"/>
                        <MenuItem text="PACKING CHARGES" onAction="#handlePackingCharges"/>
                        <MenuItem text="DESIGN CHARGES" onAction="#handleDesignCharges"/>
                        <MenuItem text="MISCELLANEOUS CHARGES" onAction="#handleMiscCharges"/>
                        <MenuItem text="CUSTOM ITEM" onAction="#handleCustomItem"/>
                    </items>
                </MenuButton>
                <Button fx:id="btnImportJob" onAction="#handleImportJob" text="Import from Job" styleClass="gst-btn-chip"/>
                <Button fx:id="btnClearAll" onAction="#handleClearAll" text="Clear All" styleClass="gst-btn-chip"/>
            </HBox>

            <TableView fx:id="tableItems" styleClass="invoice-jobs-table-premium, gst-table" prefHeight="450">
                <columnResizePolicy>
                    <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn text="#" prefWidth="45"/>
                    <TableColumn text="Description of Goods / Services" prefWidth="320" styleClass="gst-description-col"/>
                    <TableColumn text="HSN / SAC" prefWidth="100"/>
                    <TableColumn text="Qty" prefWidth="90"/>
                    <TableColumn text="Unit" prefWidth="80"/>
                    <TableColumn text="Rate (₹)" prefWidth="100"/>
                    <TableColumn text="Taxable Value (₹)" prefWidth="140"/>
                    <TableColumn text="GST %" prefWidth="80"/>
                    <TableColumn text="CGST (₹)" prefWidth="100"/>
                    <TableColumn text="SGST (₹)" prefWidth="100"/>
                    <TableColumn text="IGST (₹)" prefWidth="100"/>
                    <TableColumn text="Total (₹)" prefWidth="120"/>
                    <TableColumn text="Action" prefWidth="100"/>
                </columns>
            </TableView>

            <Button fx:id="btnEditTerms" onAction="#handleEditTerms" text="+ Add Notes / Terms for this Invoice" styleClass="gst-inline-toggle"/>

            <HBox spacing="12">
                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="gst-subcard">
                    <Label text="HSN / SAC Summary" styleClass="gst-subtitle"/>
                    <TableView fx:id="tableHsnSummary" styleClass="invoice-jobs-table-premium, gst-table" prefHeight="140">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn text="HSN / SAC" prefWidth="90"/>
                            <TableColumn text="Taxable Value (₹)" prefWidth="120"/>
                            <TableColumn text="GST %" prefWidth="70"/>
                            <TableColumn text="CGST (₹)" prefWidth="90"/>
                            <TableColumn text="SGST (₹)" prefWidth="90"/>
                            <TableColumn text="IGST (₹)" prefWidth="90"/>
                            <TableColumn text="Total Tax (₹)" prefWidth="110"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="gst-subcard">
                    <Label text="Tax Amount (in words)" styleClass="gst-subtitle"/>
                    <Label fx:id="lblTaxAmountWords" text="—" wrapText="true" styleClass="gst-tax-words"/>
                </VBox>
            </HBox>
        </VBox>

        <HBox spacing="12">
            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="gst-card" prefWidth="300">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="gst-card-icon, icon-terms"/>
                    <Label text="Terms &amp; Conditions" styleClass="gst-card-title"/>
                </HBox>
                <Label fx:id="lblTermsFooter" wrapText="true" styleClass="gst-muted"/>
            </VBox>

            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="gst-card" prefWidth="300">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="gst-card-icon, icon-bank"/>
                    <Label text="Bank Details" styleClass="gst-card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <GridPane hgap="12" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="70"/>
                    </columnConstraints>

                    <Label text="Select Bank" styleClass="gst-muted" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="comboBankDetails" promptText="INDIAN OVERSEAS BANK" styleClass="card-combo" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="INDIAN OVERSEAS BANK"/>
                                <String fx:value="STATE BANK OF INDIA"/>
                                <String fx:value="HDFC BANK"/>
                                <String fx:value="ICICI BANK"/>
                            </FXCollections>
                        </items>
                    </ComboBox>

                    <Label text="A/c Holder’s Name" styleClass="gst-muted" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label text="SUNNY PRINTER" styleClass="gst-strong" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="A/c No." styleClass="gst-muted" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label text="15980200000000780" styleClass="gst-strong" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Branch &amp; IFSC" styleClass="gst-muted" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label text="PITAMPURA &amp; IOBA0001598" styleClass="gst-strong" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                </GridPane>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
