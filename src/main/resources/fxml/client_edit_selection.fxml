<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox spacing="0" styleClass="client-directory-root, ui-compact"
      onMouseClicked="#handleRootClick"
      stylesheets="@../css/client_edit_selection.css"
      focusTraversable="true"
      xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ClientEditSelectionController"
      minWidth="600">

    <!-- BREADCRUMBS -->
    <HBox styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="8">
        <VBox.margin><Insets bottom="10"/></VBox.margin>
        <Button fx:id="breadcrumbBackBtn" onAction="#handleBack" styleClass="breadcrumb-back-btn" focusTraversable="false">
            <graphic><Region styleClass="back-icon"/></graphic>
        </Button>
        <Label text="CLIENTS" styleClass="breadcrumb-label" />
        <Label text="›" styleClass="breadcrumb-separator" />
        <Label text="EDIT SELECTION" styleClass="breadcrumb-label, breadcrumb-current" />
    </HBox>

    <Label text="Edit Client" styleClass="page-heading">
        <VBox.margin><Insets bottom="12"/></VBox.margin>
    </Label>

    <!-- SEARCH & FILTERS -->
    <HBox styleClass="search-filter-container" spacing="12">
        <StackPane>
            <TextField fx:id="searchField" promptText="Search by client name, business name, phone, email..."
                       styleClass="directory-search-field" />
            <Region style="-fx-shape: 'M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z'; -fx-background-color: #A7A69D; -fx-min-width: 16; -fx-max-width: 16; -fx-min-height: 16; -fx-max-height: 16;" 
                    StackPane.alignment="CENTER_LEFT">
                <StackPane.margin><Insets left="15"/></StackPane.margin>
            </Region>
        </StackPane>
        
        <ComboBox fx:id="statusCombo" promptText="All Status" styleClass="filter-combo" />
        <ComboBox fx:id="riskCombo" promptText="All Risk Level" styleClass="filter-combo" />
    </HBox>

    <!-- SYNCHRONIZED SCROLL AREA -->
    <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" fitToHeight="true" fitToWidth="false" VBox.vgrow="ALWAYS" styleClass="directory-master-hscroll">
        <VBox minWidth="1160" spacing="0">
            <padding><Insets top="8"/></padding>
            <!-- LIST HEADER -->
            <GridPane styleClass="directory-header">
                <columnConstraints>
                    <ColumnConstraints minWidth="250" prefWidth="250" />
                    <ColumnConstraints minWidth="200" prefWidth="200" />
                    <ColumnConstraints minWidth="120" prefWidth="120" />
                    <ColumnConstraints minWidth="220" prefWidth="220" />
                    <ColumnConstraints minWidth="120" prefWidth="120" />
                    <ColumnConstraints minWidth="100" prefWidth="100" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150" prefWidth="150" />
                </columnConstraints>
                <Label text="CLIENT" styleClass="header-label" GridPane.columnIndex="0"/>
                <Label text="PRIMARY CONTACT" styleClass="header-label" GridPane.columnIndex="1"/>
                <Label text="PHONE" styleClass="header-label" GridPane.columnIndex="2" alignment="CENTER" maxWidth="Infinity"/>
                <Label text="EMAIL" styleClass="header-label" GridPane.columnIndex="3" alignment="CENTER" maxWidth="Infinity"/>
                <Label text="RISK LEVEL" styleClass="header-label" GridPane.columnIndex="4"/>
                <Label text="STATUS" styleClass="header-label" GridPane.columnIndex="5"/>
                <Label text="ACTIONS" styleClass="header-label" GridPane.columnIndex="6" alignment="CENTER" maxWidth="Infinity"/>
            </GridPane>

            <!-- CLIENT LIST (Vertical Only) -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS" styleClass="directory-scroll">
                <VBox fx:id="clientListContainer" spacing="0">
                    <!-- Data will be populated by controller -->
                </VBox>
            </ScrollPane>
        </VBox>
    </ScrollPane>

    <!-- FOOTER / PAGINATION -->
    <HBox alignment="CENTER_LEFT" styleClass="pagination-container">
        <HBox spacing="4">
            <Label text="Showing" styleClass="footer-text" />
            <Label fx:id="lblShowingCount" text="0 of 0" styleClass="footer-text" />
            <Label text="directory entries." styleClass="footer-text" />
            <Label text="Export selection" styleClass="footer-link" style="-fx-cursor: hand; -fx-padding: 0 0 0 10;" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox fx:id="paginationContainer" spacing="8" alignment="CENTER">
            <!-- Pagination buttons & Go to generated by controller -->
        </HBox>
    </HBox>
</VBox>
