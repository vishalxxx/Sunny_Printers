<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="settings-master-scroll, settings-theme-root, ui-compact"
            stylesheets="@../css/theme.css, @../css/add_job.css, @../css/view_job.css, @../css/client_edit_selection.css, @../css/settings_screens.css"
            fx:controller="controller.UserManagementController">

    <StackPane fx:id="userManagementRoot" style="-fx-background-color: transparent;">
        
        <!-- ADMIN CONTAINER (FULL INTERFACE) -->
        <VBox fx:id="adminContainer" styleClass="settings-page, app-page-shell" alignment="TOP_LEFT" fillWidth="true" visible="true" managed="true">
            
            <HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="8"/>

            <!-- Header Section -->
            <VBox spacing="4" style="-fx-padding: 0 0 10 0;">
                <Label text="SECURITY &amp; ACCESS" styleClass="settings-section-kicker"/>
                <Label text="User Permissions" styleClass="settings-hero-title"/>
                <Label text="Configure team access, assign system roles, and synchronize with Supabase Cloud." style="-fx-font-size: 13; -fx-text-fill: #8E7B71;"/>
            </VBox>

            <!-- Main Layout Split -->
            <HBox spacing="20" alignment="TOP_LEFT" fillHeight="true">
                
                <!-- LEFT COLUMN: Create User Form (prefWidth 360) -->
                <VBox spacing="15" prefWidth="360" minWidth="360" styleClass="settings-form-card">
                    <VBox spacing="4">
                        <Label text="REGISTER MEMBER" styleClass="settings-section-kicker"/>
                        <Label text="New Team Account" style="-fx-font-size: 16; -fx-font-weight: 800; -fx-text-fill: #3E312D;"/>
                    </VBox>
                    
                    <Separator/>

                    <!-- Username -->
                    <VBox spacing="6">
                        <Label text="USERNAME / ID" styleClass="form-label"/>
                        <TextField fx:id="usernameField" promptText="e.g. alex_rivera" styleClass="text-field"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="6">
                        <Label text="PASSWORD" styleClass="form-label"/>
                        <PasswordField fx:id="passwordField" promptText="Min. 6 characters" styleClass="password-field"/>
                    </VBox>

                    <!-- Role Selector -->
                    <VBox spacing="6">
                        <Label text="ASSIGN SYSTEM ROLE" styleClass="form-label"/>
                        <ComboBox fx:id="roleComboBox" styleClass="combo-box" maxWidth="Infinity" style="-fx-min-height: 44;"/>
                    </VBox>

                    <Separator/>

                    <!-- Register Action Button -->
                    <Button fx:id="btnAddUser" text="Add User" onAction="#handleAddUser" styleClass="button, btn-primary" maxWidth="Infinity" style="-fx-min-height: 44; -fx-font-size: 13;"/>

                    <HBox spacing="8" alignment="CENTER" style="-fx-padding: 5 0 0 0;">
                        <Region style="-fx-shape: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z'; -fx-background-color: #8E7A6B; -fx-min-width: 14; -fx-max-width: 14; -fx-min-height: 14; -fx-max-height: 14;"/>
                        <Label text="New users are saved locally and automatically synchronized." style="-fx-font-size: 10px; -fx-text-fill: #8E7A6B; -fx-wrap-text: true;" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- RIGHT COLUMN: Active Users Table & Search -->
                <VBox spacing="15" HBox.hgrow="ALWAYS" styleClass="settings-form-card">
                    
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <VBox spacing="4">
                            <Label text="USER REGISTRY" styleClass="settings-section-kicker"/>
                            <Label text="Active User Accounts" style="-fx-font-size: 16; -fx-font-weight: 800; -fx-text-fill: #3E312D;"/>
                        </VBox>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <HBox alignment="CENTER_RIGHT" spacing="10">
                            <Label fx:id="lblNetworkStatus" text="Checking Connection..." style="-fx-font-size: 11px; -fx-text-fill: #8E7B71;"/>
                            <Button text="↻" onAction="#refreshData" styleClass="button, btn-secondary" style="-fx-padding: 4 10; -fx-min-height: 28; -fx-font-size: 14; -fx-cursor: hand;"/>
                        </HBox>
                    </HBox>
                    
                    <Separator/>

                    <!-- Filter strip (client edit selection pattern) -->
                    <StackPane maxWidth="Infinity">
                        <TextField fx:id="searchField"
                                   promptText="Search registered users by username or role..."
                                   styleClass="directory-search-field"
                                   maxWidth="Infinity"
                                   style="-fx-padding: 10 12 10 35;"/>
                        <Region style="-fx-shape: 'M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z'; -fx-background-color: #CD7B4E; -fx-min-width: 14; -fx-max-width: 14; -fx-min-height: 14; -fx-max-height: 14;"
                                StackPane.alignment="CENTER_LEFT">
                            <StackPane.margin><Insets left="15"/></StackPane.margin>
                        </Region>
                    </StackPane>

                    <!-- TableView -->
                    <TableView fx:id="usersTable" styleClass="table-view" VBox.vgrow="ALWAYS" style="-fx-min-height: 300;" focusTraversable="false">
                        <columns>
                            <TableColumn fx:id="colUsername" text="Username" prefWidth="180"/>
                            <TableColumn fx:id="colRole" text="System Role" prefWidth="140"/>
                            <TableColumn fx:id="colSyncStatus" text="Sync State" prefWidth="120"/>
                        </columns>
                        <placeholder>
                            <Label text="No matching user records found." style="-fx-font-style: italic; -fx-text-fill: #8E7B71;"/>
                        </placeholder>
                    </TableView>
                </VBox>

            </HBox>
        </VBox>
        
        <!-- ACCESS DENIED CONTAINER (SECURE FALLBACK) -->
        <VBox fx:id="accessDeniedContainer" alignment="CENTER" spacing="20" visible="false" managed="false" style="-fx-padding: 80 40 80 40;">
            <StackPane style="-fx-background-color: #FDF4ED; -fx-background-radius: 100; -fx-padding: 20; -fx-max-width: 80; -fx-max-height: 80;">
                <Region style="-fx-shape: 'M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z'; -fx-background-color: #B25D3B; -fx-min-width: 36; -fx-max-width: 36; -fx-min-height: 36; -fx-max-height: 36;"/>
            </StackPane>
            
            <VBox alignment="CENTER" spacing="6">
                <Label text="ACCESS RESTRICTED" styleClass="settings-section-kicker"/>
                <Label text="Administrator Privileges Required" styleClass="settings-hero-title" style="-fx-text-fill: #3E312D;"/>
                <Label text="Your current team account does not have authorization to view or manage security controls.\nPlease consult your system administrator for permissions." 
                       alignment="CENTER" style="-fx-font-size: 13px; -fx-text-fill: #8E7B71; -fx-text-alignment: center;"/>
            </VBox>
        </VBox>
        
    </StackPane>

</ScrollPane>
