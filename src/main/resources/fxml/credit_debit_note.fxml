<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.CreditDebitNoteController"
            stylesheets="@../css/theme.css, @../css/credit_debit_note.css"
            fitToWidth="true" fitToHeight="true"
            styleClass="cn-dn-scroll">

    <VBox spacing="0" styleClass="cn-dn-root" fillWidth="true">
        <padding>
            <Insets top="16" right="28" bottom="28" left="28"/>
        </padding>

        <!-- BREADCRUMBS -->
        <HBox styleClass="cn-dn-breadcrumb-container">
            <Button onAction="#handleBack" styleClass="breadcrumb-back-btn" focusTraversable="false">
                <graphic><Region styleClass="back-icon"/></graphic>
            </Button>
            <Label text="INVOICES" styleClass="cn-dn-breadcrumb-label" />
            <Label text="›" styleClass="cn-dn-breadcrumb-separator" />
            <Label text="CREDIT / DEBIT NOTE" styleClass="cn-dn-breadcrumb-current" />
        </HBox>

        <!-- HEADER -->
        <VBox spacing="4" styleClass="cn-dn-header-container">
            <Label text="Credit / Debit Note" styleClass="cn-dn-title"/>
            <Label text="Generate a credit or debit note for a client." styleClass="cn-dn-subtitle"/>
        </VBox>

        <Region prefHeight="16" />

        <!-- FORM CONTAINER -->
        <StackPane>
            <VBox spacing="24" styleClass="cn-dn-card" maxWidth="800">
                
                <!-- ROW 1: TYPE & CLIENT -->
                <HBox spacing="20">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Note Type" styleClass="cn-dn-field-label"/>
                        <ComboBox fx:id="noteTypeComboBox"
                                  promptText="Select Type..."
                                  maxWidth="400"
                                  prefWidth="350"
                                  styleClass="taste-combo"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Select Client" styleClass="cn-dn-field-label"/>
                        <ComboBox fx:id="clientComboBox"
                                  promptText="Select a client..."
                                  maxWidth="400"
                                  prefWidth="350"
                                  styleClass="taste-combo"/>
                    </VBox>
                </HBox>
                
                <!-- ROW 2: INVOICE & DATE -->
                <HBox spacing="20">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Select Invoice" styleClass="cn-dn-field-label"/>
                        <ComboBox fx:id="invoiceComboBox"
                                  promptText="Select an invoice..."
                                  maxWidth="400"
                                  prefWidth="350"
                                  styleClass="taste-combo"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Date" styleClass="cn-dn-field-label"/>
                        <DatePicker fx:id="datePicker"
                                    promptText="Select Date"
                                    maxWidth="400"
                                    prefWidth="350"
                                    styleClass="taste-datepicker"/>
                    </VBox>
                </HBox>

                <!-- ROW 3: AMOUNT -->
                <VBox spacing="6">
                    <Label text="Amount" styleClass="cn-dn-field-label"/>
                    <TextField fx:id="amountField" promptText="Enter amount" styleClass="taste-field" />
                </VBox>

                <!-- ROW 4: REASON -->
                <VBox spacing="6">
                    <Label text="Reason / Remarks" styleClass="cn-dn-field-label"/>
                    <TextArea fx:id="reasonField" prefRowCount="3" promptText="Enter reason..." styleClass="card-textarea" />
                </VBox>

                <Region prefHeight="10"/>

                <!-- ACTIONS -->
                <Button text="Save Note" 
                        maxWidth="Infinity" 
                        styleClass="cn-dn-save-btn" 
                        onAction="#handleSaveNote">
                    <graphic>
                        <Label text="✔" style="-fx-text-fill: white; -fx-font-size: 1.2em; -fx-font-weight: 900; -fx-padding: 0 8 0 0;"/>
                    </graphic>
                </Button>
            </VBox>
        </StackPane>
    </VBox>
</ScrollPane>

