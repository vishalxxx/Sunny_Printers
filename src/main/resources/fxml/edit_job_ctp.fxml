<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.CtpTabController"
      spacing="16"
      styleClass="tab-container">



    <!-- ===== LEFT TABLE ===== -->
      <VBox styleClass="table-wrapper" HBox.hgrow="ALWAYS"  prefWidth="650">
     
     <TableView fx:id="ctpTable" styleClass="data-table">

    <columns>
         <TableColumn fx:id="statusCol"  text="Status" prefWidth="110"/>

        <TableColumn fx:id="supplierCol" text="Supplier"/>
        <TableColumn fx:id="qtyCol" text="Qty"/>
        <TableColumn fx:id="colorCol" text="Color"/>
		<TableColumn fx:id="backingCol" text="Backing"/>

        <TableColumn fx:id="plateSizeCol" text="Plate Size"/>
        <TableColumn fx:id="gaugeCol" text="Gauge"/>
        <TableColumn fx:id="notesCol" text="Notes"/>

        <TableColumn fx:id="amountCol" text="Amount"/>
    </columns>

    <placeholder>
        <VBox alignment="CENTER" spacing="10" styleClass="tab-empty-state">
            <Region styleClass="tab-empty-icon"/>
            <Label text="No Content to show" styleClass="tab-empty-title"/>
        </VBox>
    </placeholder>

</TableView>

     

    </VBox>

    <!-- ===== RIGHT PANEL ===== -->
   <!-- ===== RIGHT PANEL : CTP / PLATES EDITOR ===== -->
<!-- ===== RIGHT PANEL : CTP / PLATES EDITOR ===== -->

<VBox styleClass="editor-panel"
      spacing="12"
      fx:id="rightPane"
      prefWidth="350">

    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                styleClass="editor-panel-scroll"
                VBox.vgrow="ALWAYS">
        <content>
            <VBox spacing="12" styleClass="editor-panel-content" fillWidth="true">
                <Label text="CTP / Plates Editor"
                       styleClass="card-title"/>

                <GridPane hgap="12" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                    </columnConstraints>

                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
                        <Label text="Supplier"/>
                        <ComboBox fx:id="supplierField"
                                  promptText="Select supplier"
                                  maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="Quantity"/>
                        <TextField fx:id="qtyField"
                                   promptText="Enter quantity"
                                   maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="Plate Size"/>
                        <ComboBox fx:id="plateSizeField"
                                  promptText="Select size"
                                  maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="Gauge"/>
                        <ComboBox fx:id="gaugeField"
                                  promptText="Select gauge"
                                  maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label text="Backing"/>
                        <ComboBox fx:id="backingField"
                                  promptText="Select backing"
                                  maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <Label text="Color"/>
                        <ComboBox fx:id="colorField"
                                  promptText="Select color"
                                  maxWidth="Infinity"/>
                    </VBox>

                    <Region GridPane.columnIndex="1" GridPane.rowIndex="3" />
                </GridPane>

                <VBox spacing="6">
                    <Label text="Notes"/>
                    <TextArea fx:id="notesField"
                              prefRowCount="2"
                              wrapText="true"
                              promptText="Optional notes"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Amount (₹)"/>
                    <TextField fx:id="amountField"
                               promptText="Enter amount"/>
                </VBox>

                <HBox spacing="10" HBox.hgrow="ALWAYS">
                    <Button fx:id="addUpdateBtn"
                            text="Add CTP"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"
                            styleClass="btn-primary"
                            onAction="#handleAddOrUpdate"/>

                    <Button fx:id="deleteBtn"
                            text="Delete"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"
                            onAction="#handleDelete"
                            visible="false"
                            managed="false"
                            styleClass="btn-danger"/>
                </HBox>
            </VBox>
        </content>
    </ScrollPane>


</VBox>

</HBox>
