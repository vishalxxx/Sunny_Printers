<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            hbarPolicy="AS_NEEDED"
            vbarPolicy="AS_NEEDED"
            styleClass="settings-master-scroll, settings-theme-root, ui-compact, settings-screen-compact"
            stylesheets="@../css/theme.css, @../css/add_job.css, @../css/view_job.css, @../css/client_edit_selection.css, @../css/settings_screens.css"
            fx:controller="controller.CompanySettingsController">

    <VBox styleClass="settings-page, app-page-shell" alignment="TOP_LEFT" fillWidth="true">

        <HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="6"/>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding><Insets bottom="6"/></padding>
            <Button fx:id="newBtn" text="+ New Company" styleClass="button, btn-secondary"/>
            <Button fx:id="saveBtn" text="Save" styleClass="button, btn-primary"/>
        </HBox>

        <HBox spacing="10" alignment="TOP_LEFT" fillHeight="true">

            <VBox styleClass="settings-form-card" spacing="8" HBox.hgrow="ALWAYS" minWidth="0">
                <Label text="Saved companies" styleClass="card-title-sm"/>
                <Label text="Used as invoice letterhead and numbering prefix." wrapText="true" styleClass="settings-section-kicker"/>

                <TableView fx:id="companyTable" styleClass="invoice-jobs-table-premium" prefHeight="260" minHeight="140" maxWidth="Infinity">
                    <columnResizePolicy>
                        <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colTrade" text="Trade name" prefWidth="168"/>
                        <TableColumn fx:id="colGstin" text="GSTIN" prefWidth="118"/>
                        <TableColumn fx:id="colPhone" text="Phone" prefWidth="100"/>
                        <TableColumn fx:id="colAltPhone" text="Alt Phone" prefWidth="100"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="148"/>
                        <TableColumn fx:id="colDefault" text="Default" prefWidth="72"/>
                        <TableColumn fx:id="colActive" text="Active" prefWidth="72"/>
                    </columns>
                </TableView>

                <HBox spacing="6" alignment="CENTER_RIGHT">
                    <Button fx:id="deleteBtn" text="Delete" styleClass="button, btn-secondary"/>
                </HBox>
            </VBox>

            <VBox styleClass="settings-form-card" spacing="10" HBox.hgrow="ALWAYS" minWidth="0">
                <Label text="Company details" styleClass="card-title-sm"/>
                <Label text="Select a row to edit, or click New Company." wrapText="true" styleClass="settings-section-kicker"/>

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                    </columnConstraints>

                    <VBox spacing="4" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="0">
                        <Label text="Company / trade name" styleClass="field-heading-sm"/>
                        <TextField fx:id="tradeNameField" promptText="Your business name" styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="4" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                        <Label text="Address" styleClass="field-heading-sm"/>
                        <TextArea fx:id="addressArea" promptText="Street, city, PIN (multiple lines OK)" styleClass="taste-field" wrapText="true" prefRowCount="3" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="Phone" styleClass="field-heading-sm"/>
                        <TextField fx:id="phoneField" promptText="10-digit phone number" styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label text="Alt phone (optional)" styleClass="field-heading-sm"/>
                        <TextField fx:id="altPhoneField" promptText="Alternate phone number" styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <Label text="Email" styleClass="field-heading-sm"/>
                        <TextField fx:id="emailField" promptText="company@example.com" styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="3">
                        <Label text="GST / UIN" styleClass="field-heading-sm"/>
                        <TextField fx:id="gstinField" promptText="GSTIN/UIN" styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="4">
                        <Label text="State (optional)" styleClass="field-heading-sm"/>
                        <TextField fx:id="stateField" promptText="e.g. Delhi (07)" styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>

                    <HBox spacing="8" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="5">
                        <CheckBox fx:id="defaultCheck" text="Make default" styleClass="gst-radio"/>
                        <CheckBox fx:id="activeCheck" text="Active" styleClass="gst-radio" selected="true"/>
                    </HBox>
                </GridPane>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>

