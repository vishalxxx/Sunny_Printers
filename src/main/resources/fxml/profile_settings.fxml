<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<ScrollPane fitToWidth="true" styleClass="profile-root" stylesheets="@../css/user_profile.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ProfileSettingsController">
    <VBox spacing="40" styleClass="content-container">
        <padding>
            <Insets bottom="40" left="60" right="60" top="40" />
        </padding>

        <!-- HEADER / AVATAR ROW -->
        <HBox alignment="CENTER_LEFT" spacing="35">
            <StackPane styleClass="profile-avatar-container">
                <Circle fill="WHITE" radius="70" />
                <ImageView fx:id="profileImageView" fitHeight="140" fitWidth="140" preserveRatio="true">
                    <image>
                        <Image url="@../icons/contact.png" />
                    </image>
                    <clip>
                        <Circle radius="70" centerX="70" centerY="70" />
                    </clip>
                </ImageView>
            </StackPane>
            
            <VBox spacing="10">
                <Label text="Account Settings" styleClass="profile-role-subtitle" />
                <Label text="Alex Mercer" styleClass="profile-name-title" />
                <Button onAction="#handleChangePhoto" styleClass="btn-ghost-small" text="Change Profile Photo" />
            </VBox>
        </HBox>

        <Separator opacity="0.1" />

        <!-- SETTINGS GRID -->
        <HBox spacing="50">
            <!-- ACCOUNT FORM -->
            <VBox spacing="30" styleClass="settings-card" HBox.hgrow="ALWAYS">
                <Label styleClass="card-section-title" text="Personal Information" />
                
                <GridPane hgap="30" vgap="25">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" />
                        <ColumnConstraints percentWidth="50" />
                    </columnConstraints>
                    
                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label styleClass="input-label" text="USERNAME" />
                        <TextField fx:id="usernameField" editable="false" styleClass="input-field-read" text="alex_mercer" />
                    </VBox>
                    
                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label styleClass="input-label" text="ROLE" />
                        <TextField fx:id="roleField" editable="false" styleClass="input-field-read" text="Production Manager" />
                    </VBox>
                    
                    <VBox spacing="8" GridPane.columnSpan="2" GridPane.rowIndex="1">
                        <Label styleClass="input-label" text="NEW PASSWORD" />
                        <PasswordField fx:id="newPasswordField" promptText="••••••••" styleClass="input-field" />
                    </VBox>
                    
                    <VBox spacing="8" GridPane.columnSpan="2" GridPane.rowIndex="2">
                        <Label styleClass="input-label" text="CONFIRM NEW PASSWORD" />
                        <PasswordField fx:id="confirmPasswordField" promptText="••••••••" styleClass="input-field" />
                    </VBox>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                    <Button onAction="#handleSave" styleClass="btn-primary-large" text="Save Preferences" />
                </HBox>
            </VBox>

            <!-- INFO SIDEBAR -->
            <VBox prefWidth="300" spacing="25">
                <VBox styleClass="info-card-subtle">
                    <Label styleClass="card-sub-title" text="Security Status" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                         <Label styleClass="status-pill-green" text="Two-Factor Enabled" />
                    </HBox>
                    <Label styleClass="info-subtext" text="Your account is secured with biometric verification and encrypted sessions." wrapText="true" />
                </VBox>
                
                <VBox styleClass="info-card-subtle" style="-fx-background-color: #FFFFFF; -fx-border-color: #F1EBE5; -fx-border-radius: 20; -fx-border-width: 1;">
                    <Label styleClass="card-sub-title" text="Need Help?" />
                    <Label styleClass="info-subtext" text="If you're having trouble accessing certain modules, contact the administrator for permission updates." wrapText="true" />
                    <Button styleClass="btn-ghost-small" style="-fx-padding: 0;" text="Visit Support Center" />
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
