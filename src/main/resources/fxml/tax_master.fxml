<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="taxMasterScroll" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
            styleClass="settings-master-scroll, settings-theme-root, ui-compact, settings-screen-compact, tax-master-compact"
            fx:controller="controller.TaxMasterController">

    <VBox styleClass="settings-page, app-page-shell" alignment="TOP_LEFT" fillWidth="true">

        <HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="6"/>

        <HBox spacing="10" alignment="TOP_LEFT" fillHeight="true" VBox.vgrow="ALWAYS">

            <VBox styleClass="settings-form-card" spacing="8" minWidth="280" HBox.hgrow="ALWAYS">

                <GridPane hgap="8" maxWidth="Infinity" styleClass="tax-master-toolbar">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="40" hgrow="ALWAYS" minWidth="120"/>
                        <ColumnConstraints percentWidth="34" hgrow="ALWAYS" minWidth="140"/>
                        <ColumnConstraints percentWidth="26" hgrow="ALWAYS" minWidth="100"/>
                    </columnConstraints>
                    <TextField fx:id="txtSearch" GridPane.columnIndex="0" GridPane.rowIndex="0"
                               promptText="Search by item name or HSN/SAC..."
                               styleClass="taste-field, tax-master-toolbar-search" maxWidth="Infinity"/>
                    <ComboBox fx:id="comboCategory" GridPane.columnIndex="1" GridPane.rowIndex="0"
                              promptText="All Categories" styleClass="taste-field, tax-master-toolbar-combo" maxWidth="Infinity"/>
                    <ComboBox fx:id="comboTypeFilter" GridPane.columnIndex="2" GridPane.rowIndex="0"
                              promptText="All Types" styleClass="taste-field, tax-master-toolbar-combo" maxWidth="Infinity"/>
                </GridPane>

                <TableView fx:id="tableTax" styleClass="invoice-jobs-table-premium, tax-master-table-fulltext" prefHeight="260" minHeight="140"
                           maxWidth="Infinity" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colNum" text="#" prefWidth="34" maxWidth="42"/>
                        <TableColumn fx:id="colItemName" text="Item Name" prefWidth="200" minWidth="120"/>
                        <TableColumn fx:id="colCategory" text="Category" prefWidth="82"/>
                        <TableColumn fx:id="colCode" text="HSN/SAC" prefWidth="100" minWidth="72"/>
                        <TableColumn fx:id="colKind" text="Type" prefWidth="56"/>
                        <TableColumn fx:id="colGst" text="GST Rate (%)" prefWidth="92"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="72"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="84"/>
                    </columns>
                </TableView>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label fx:id="lblPageInfo" text="" styleClass="settings-section-kicker" HBox.hgrow="ALWAYS"/>
                    <HBox spacing="4" alignment="CENTER_RIGHT">
                        <Button fx:id="btnPrev" text="&#8249;" styleClass="button, btn-secondary" onAction="#handlePrevPage"/>
                        <HBox fx:id="boxPageNumbers" spacing="3" alignment="CENTER_LEFT"/>
                        <Button fx:id="btnNext" text="&#8250;" styleClass="button, btn-secondary" onAction="#handleNextPage"/>
                    </HBox>
                </HBox>

                <HBox spacing="8" alignment="CENTER_LEFT" fillHeight="false" styleClass="tax-master-footer-strip">
                    <Region styleClass="tax-master-footer-info-ico"/>
                    <Label text="Note: Do not delete tax items used in invoices. Deactivate them instead to maintain historical data."
                           wrapText="true" styleClass="settings-section-kicker" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnToggleInactive" text="View Inactive Items" styleClass="button, btn-secondary"
                            contentDisplay="LEFT" onAction="#handleToggleInactive">
                        <graphic>
                            <Region styleClass="tax-master-icon-eye"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox fx:id="formPanel" styleClass="settings-form-card" spacing="10" minWidth="256" prefWidth="300" maxWidth="340" HBox.hgrow="SOMETIMES">
                <Label fx:id="lblFormTitle" text="Add New Tax Item" styleClass="card-title-sm" maxWidth="Infinity"/>

                <VBox spacing="8" fillWidth="true">
                    <VBox spacing="4">
                        <HBox spacing="3" alignment="CENTER_LEFT">
                            <Label text="Item Name" styleClass="field-heading-sm"/>
                            <Label text="*" styleClass="tax-master-req-star"/>
                        </HBox>
                        <TextField fx:id="fldItemName" promptText="Enter item or service name" styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4">
                        <HBox spacing="3" alignment="CENTER_LEFT">
                            <Label text="Category" styleClass="field-heading-sm"/>
                            <Label text="*" styleClass="tax-master-req-star"/>
                        </HBox>
                        <ComboBox fx:id="fldCategory" promptText="Select category" styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4">
                        <HBox spacing="3" alignment="CENTER_LEFT">
                            <Label text="HSN / SAC Code" styleClass="field-heading-sm"/>
                            <Label text="*" styleClass="tax-master-req-star"/>
                        </HBox>
                        <TextField fx:id="fldHsnSac" promptText="Enter HSN/SAC code (required)" styleClass="taste-field" maxWidth="Infinity">
                            <tooltip>
                                <Tooltip text="Mandatory for GST invoices. Use numeric HSN or SAC service codes from your catalog."/>
                            </tooltip>
                        </TextField>
                    </VBox>
                    <VBox spacing="4">
                        <HBox spacing="3" alignment="CENTER_LEFT">
                            <Label text="Type" styleClass="field-heading-sm"/>
                            <Label text="*" styleClass="tax-master-req-star"/>
                        </HBox>
                        <ComboBox fx:id="fldCodeType" promptText="Select type (HSN or SAC)" styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4">
                        <HBox spacing="3" alignment="CENTER_LEFT">
                            <Label text="GST Rate (%)" styleClass="field-heading-sm"/>
                            <Label text="*" styleClass="tax-master-req-star"/>
                        </HBox>
                        <ComboBox fx:id="fldGstRate" promptText="Select GST rate" styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Unit default" styleClass="field-heading-sm"/>
                        <TextField fx:id="fldUnit" promptText="PCS, SHEET, SET..." styleClass="taste-field" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Description (Optional)" styleClass="field-heading-sm"/>
                        <TextArea fx:id="fldDescription" promptText="Enter description..." wrapText="true" prefRowCount="2" prefHeight="56" styleClass="taste-field, tax-master-description-area" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4">
                        <CheckBox fx:id="chkFavorite" text="Set as Favorite" styleClass="settings-check"/>
                        <Label text="Favorite items will appear on top in dropdowns." styleClass="settings-section-kicker"/>
                    </VBox>
                    <HBox spacing="6" alignment="CENTER_RIGHT">
                        <Button fx:id="btnCancelForm" text="Cancel" styleClass="button, btn-secondary" onAction="#handleCancelForm"/>
                        <Button fx:id="btnSave" text="Save Item" styleClass="button, btn-primary" onAction="#handleSave"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>