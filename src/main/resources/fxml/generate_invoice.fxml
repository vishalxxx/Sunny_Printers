<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<ScrollPane xmlns="http://javafx.com/javafx/23" 
            xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true" 
            styleClass="main-scroll-pane, taste-root"
            stylesheets="@../css/theme.css, @../css/generate_invoice.css"
            fx:controller="controller.GenerateInvoiceController">

    <VBox spacing="24" styleClass="root-container, generate-invoice-root">
        <padding>
            <Insets top="20" right="30" bottom="30" left="30" />
        </padding>

        <!-- 1. BREADCRUMBS -->
        <HBox styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="12">
            <Button fx:id="breadcrumbBackBtn" onAction="#handleBack" styleClass="breadcrumb-back-btn">
                <graphic><Region styleClass="back-icon"/></graphic>
            </Button>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Invoices" styleClass="breadcrumb-label" />
                <Label text="›" styleClass="breadcrumb-separator" />
                <Label text="Generate Invoice" styleClass="breadcrumb-label, breadcrumb-current" />
            </HBox>
        </HBox>

        <!-- 2. TABS SECTION -->
        <HBox spacing="32" styleClass="tab-header">
            <VBox styleClass="tab-item, tab-active">
                <Label text="Selected Jobs" styleClass="tab-label"/>
                <Region styleClass="tab-indicator"/>
            </VBox>
            <VBox styleClass="tab-item">
                <Label text="Date Range" styleClass="tab-label"/>
                <Region styleClass="tab-indicator"/>
            </VBox>
            <VBox styleClass="tab-item">
                <Label text="Monthly" styleClass="tab-label"/>
                <Region styleClass="tab-indicator"/>
            </VBox>
        </HBox>

        <!-- 3. MAIN LAYOUT: fillHeight=false so the left card is not stretched to match the right column -->
        <HBox spacing="24" alignment="TOP_LEFT" fillHeight="false" VBox.vgrow="NEVER">
            <!-- LEFT PANEL: JOB SELECTION -->
            <VBox fx:id="jobsCard" spacing="16" HBox.hgrow="ALWAYS" styleClass="content-card" fillWidth="true">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Select Jobs" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane maxWidth="260" prefWidth="260" minWidth="260" styleClass="invoice-job-search-wrap">
                        <TextField fx:id="jobSearchField" promptText="Search jobs..." styleClass="invoice-directory-search-field"/>
                        <Region styleClass="invoice-directory-search-glyph" mouseTransparent="true" StackPane.alignment="CENTER_LEFT">
                            <StackPane.margin>
                                <Insets left="15"/>
                            </StackPane.margin>
                        </Region>
                    </StackPane>
                </HBox>

                <TableView fx:id="jobsTable" VBox.vgrow="NEVER" styleClass="invoice-jobs-table">
                    <columns>
                        <TableColumn fx:id="selectCol" prefWidth="48" minWidth="48" maxWidth="52" resizable="false" sortable="false">
                            <graphic><CheckBox fx:id="selectAllCheckbox"/></graphic>
                        </TableColumn>
                        <!-- Equal prefWidth so CONSTRAINED_RESIZE_POLICY shares width evenly across data columns -->
                        <TableColumn fx:id="jobNameCol" text="JOB NAME" prefWidth="120" minWidth="80" sortable="false"/>
                        <TableColumn fx:id="dateCol" text="COMPLETION DATE" prefWidth="120" minWidth="80" sortable="false"/>
                        <TableColumn fx:id="qtyCol" text="QUANTITY" prefWidth="120" minWidth="80" sortable="false"/>
                        <TableColumn fx:id="rateCol" text="UNIT AMOUNT" prefWidth="120" minWidth="80" sortable="false"/>
                        <TableColumn fx:id="totalCol" text="TOTAL" prefWidth="120" minWidth="80" sortable="false"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="8" styleClass="invoice-jobs-empty">
                            <Label text="No jobs to show" styleClass="invoice-jobs-empty-title"/>
                            <Label text="Pick a client above to load jobs, or try a different search." styleClass="invoice-jobs-empty-sub" wrapText="true" maxWidth="360" textAlignment="CENTER"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- RIGHT PANEL: INFO & SUMMARY -->
            <VBox spacing="20" minWidth="380" maxWidth="380">
                <!-- CLIENT & INVOICE INFO -->
                <VBox spacing="16" styleClass="info-card">
                    <Label text="Client &amp; Invoice Info" styleClass="card-title-sm"/>
                    
                    <VBox spacing="6">
                        <Label text="CLIENT NAME" styleClass="field-label-xs"/>
                        <ComboBox fx:id="clientComboBox" promptText="Select client name." styleClass="client-combo" maxWidth="Infinity" editable="false" />
                    </VBox>

                    <HBox spacing="12">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="INVOICE NO." styleClass="field-label-xs"/>
                            <TextField fx:id="invoiceNoField" text="INV-2023-892" styleClass="compact-field, invoice-no-input" editable="false" focusTraversable="true"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="TERMS" styleClass="field-label-xs"/>
                            <ComboBox fx:id="termsCombo" promptText="Net 30" styleClass="card-combo" maxWidth="Infinity"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="12">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="INVOICE DATE" styleClass="field-label-xs"/>
                            <DatePicker fx:id="invoiceDatePicker" promptText="mm/dd/yyyy" styleClass="compact-datepicker" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="DUE DATE" styleClass="field-label-xs"/>
                            <DatePicker fx:id="dueDatePicker" promptText="mm/dd/yyyy" styleClass="compact-datepicker" maxWidth="Infinity"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="NOTES" styleClass="field-label-xs"/>
                        <TextArea fx:id="notesArea" promptText="Add specific delivery instructions..." styleClass="card-textarea" prefHeight="80" wrapText="true"/>
                    </VBox>
                </VBox>

                <!-- INVOICE SUMMARY -->
                <VBox spacing="20" styleClass="summary-card">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Region styleClass="icon-summary-card"/>
                        <Label text="Invoice Summary" styleClass="card-title-sm"/>
                    </HBox>
                    
                    <VBox spacing="16">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Selected Items" styleClass="summary-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="itemCountLabel" text="0 jobs" styleClass="summary-value-accent"/>
                        </HBox>
                        
                        <Separator styleClass="summary-separator"/>
                        
                        <VBox spacing="8">
                            <Label text="TOTAL PAYABLE" styleClass="total-label"/>
                            <Label fx:id="totalAmountLabel" text="₹ 7,810.00" styleClass="total-value-hero"/>
                        </VBox>
                    </VBox>
                    
                    <HBox spacing="12">
                        <Button text="Preview Invoice" onAction="#handlePreview" styleClass="draft-btn-premium" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="Generate Invoice" onAction="#handleGenerate" styleClass="next-step-btn-premium" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
