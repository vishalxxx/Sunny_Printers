<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" stylesheets="@../css/theme.css, @../css/client_form.css" styleClass="center-area, ui-compact"
    xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controller.ClientFormController">
    <VBox fx:id="formShell" spacing="8" alignment="TOP_LEFT" fillWidth="true" styleClass="content-container, app-page-shell">

        <!-- PAGE TITLE (above breadcrumbs — match Edit Client layout) -->
        <VBox fx:id="pageTitleBlock" spacing="4" styleClass="app-page-title-block page-header-container">
            <HBox styleClass="header-row">
                <Label fx:id="lblTitleName" text="Business Name" styleClass="page-heading"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                <VBox alignment="TOP_RIGHT">
                    <Label text="CLIENT ID" styleClass="client-id-label" />
                    <Label fx:id="lblClientId" text="#CL-0000" styleClass="client-id-value" />
                </VBox>
            </HBox>
        </VBox>

        <!-- BREADCRUMBS -->
        <HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" spacing="8" alignment="CENTER_LEFT" />

        <VBox spacing="15" fillWidth="true" styleClass="client-form-body">
            <!-- BASIC INFO -->
            <VBox styleClass="form-card">
                <HBox styleClass="card-header">
                    <Region styleClass="card-icon, icon-basic" />
                    <Label text="Basic Information" styleClass="card-title" />
                </HBox>

                <VBox spacing="12">
                    <VBox>
                        <Label text="BUSINESS NAME" styleClass="field-label" />
                        <TextField fx:id="businessNameField" styleClass="form-input"
                            promptText="Enter business name" />
                    </VBox>
                    <VBox styleClass="input-container-inset">
                        <Label text="CLIENT NAME" styleClass="field-label" />
                        <TextField fx:id="clientNameField" styleClass="form-input"
                            promptText="Full name" />
                    </VBox>
                </VBox>
            </VBox>

            <!-- CONTACT DETAILS -->
            <VBox styleClass="form-card">
                <HBox styleClass="card-header">
                    <Region styleClass="card-icon, icon-contact" />
                    <Label text="Contact Details" styleClass="card-title" />
                </HBox>

                <VBox spacing="12">
                    <HBox spacing="15">
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="PHONE NUMBER" styleClass="field-label" />
                            <TextField fx:id="phoneField" styleClass="form-input"
                                promptText="Enter 10-digit mobile number" />
                            <Label fx:id="lblPhoneValidation" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" wrapText="true" />
                        </VBox>
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="ALT. PHONE" styleClass="field-label" />
                            <TextField fx:id="altPhoneField" styleClass="form-input"
                                promptText="Optional landline/alternate" />
                            <Label fx:id="lblAltPhoneValidation" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" wrapText="true" />
                        </VBox>
                    </HBox>
                    <VBox styleClass="input-container-inset">
                        <Label text="EMAIL ADDRESS" styleClass="field-label" />
                        <TextField fx:id="emailField" styleClass="form-input"
                            promptText="email@business.com" />
                    </VBox>
                </VBox>
            </VBox>

            <!-- BUSINESS & TAX INFO -->
            <VBox styleClass="form-card">
                <HBox styleClass="card-header">
                    <Region styleClass="card-icon, icon-tax" />
                    <Label text="Business &amp; Tax Info" styleClass="card-title" />
                </HBox>

                <VBox spacing="12">
                    <HBox spacing="20">
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="GST NUMBER" styleClass="field-label" />
                            <TextField fx:id="gstField" styleClass="form-input"
                                promptText="22AAAAA0000A1Z5" />
                            <Label fx:id="lblGstValidation" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" wrapText="true" />
                            <VBox fx:id="panGstDetails" spacing="8" style="-fx-background-color: #f8f9fa; -fx-border-color: #e9ecef; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 12px; -fx-margin-top: 10px;" visible="false" managed="false">
                                <Label text="Extracted GSTIN Details (Verified Offline)" style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #2c3e50;" />
                                <GridPane hgap="10" vgap="4">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="120" prefWidth="120" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="18" />
                                        <RowConstraints minHeight="18" />
                                        <RowConstraints minHeight="18" />
                                        <RowConstraints minHeight="18" />
                                        <RowConstraints minHeight="18" />
                                    </rowConstraints>
                                    <Label text="GSTIN:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                    <Label fx:id="lblGstDetailsGstin" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #2c3e50;" />
                                    
                                    <Label text="State Code &amp; Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                    <Label fx:id="lblGstDetailsState" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-size: 11px; -fx-text-fill: #2c3e50;" />
                                    
                                    <Label text="PAN Number:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                    <Label fx:id="lblGstDetailsPan" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-size: 11px; -fx-text-fill: #2c3e50;" />
                                    
                                    <Label text="Registration Type:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                    <Label fx:id="lblGstDetailsType" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-font-size: 11px; -fx-text-fill: #2c3e50;" />

                                    <Label text="Validation Status:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                    <Label fx:id="lblGstDetailsStatus" GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-font-size: 11px; -fx-text-fill: #27ae60; -fx-font-weight: bold;" />
                                </GridPane>
                            </VBox>
                        </VBox>
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="PAN NUMBER" styleClass="field-label" />
                            <TextField fx:id="panField" styleClass="form-input" promptText="ABCDE1234F" />
                        </VBox>
                    </HBox>
                    <HBox spacing="20">
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="CUSTOMER STATE (GST STATE)" styleClass="field-label" />
                            <ComboBox fx:id="stateCombo" promptText="Select State" styleClass="form-combo, form-input" maxWidth="Infinity" />
                        </VBox>
                    </HBox>
                    <HBox spacing="20">
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="CREDIT LIMIT" styleClass="field-label" />
                            <TextField fx:id="creditLimitField" styleClass="form-input" promptText="0.0" />
                        </VBox>
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="OPENING BALANCE" styleClass="field-label" />
                            <TextField fx:id="openingBalanceField" styleClass="form-input" promptText="0.0" />
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ADDRESS DETAILS -->
            <VBox styleClass="form-card">
                <HBox styleClass="card-header" alignment="CENTER_LEFT">
                    <Region styleClass="card-icon, icon-address" />
                    <Label text="Address Details" styleClass="card-title" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="Same as Billing Address" styleClass="switch-label" />
                    <ToggleButton fx:id="syncAddressToggle" styleClass="ios-toggle">
                        <graphic><Region styleClass="toggle-thumb" /></graphic>
                        <HBox.margin><Insets right="15" /></HBox.margin>
                    </ToggleButton>
                </HBox>

                <HBox spacing="30">
                    <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                        <Label text="BILLING ADDRESS" styleClass="field-label" />
                        <TextArea fx:id="billingAddressField" styleClass="form-textarea"
                            prefHeight="60" promptText="Enter full billing address" wrapText="true" />
                    </VBox>
                    <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                        <Label text="SHIPPING ADDRESS" styleClass="field-label" />
                        <TextArea fx:id="shippingAddressField" styleClass="form-textarea"
                            prefHeight="60" promptText="Enter full shipping address"
                            wrapText="true" />
                    </VBox>
                </HBox>
            </VBox>

            <!-- NOTES -->
            <VBox styleClass="form-card">
                <HBox styleClass="card-header">
                    <Region styleClass="card-icon, icon-notes" />
                    <Label text="Internal Notes" styleClass="card-title" />
                </HBox>
                <VBox styleClass="input-container-inset">
                    <Label text="CONFIDENTIAL NOTES" styleClass="field-label" />
                    <TextArea fx:id="notesField" styleClass="form-textarea" prefHeight="60"
                        promptText="Any specific reminders for this client..." wrapText="true" />
                </VBox>
            </VBox>
        </VBox>

        <!-- FOOTER -->
        <HBox styleClass="footer-btn-container">
            <Button text="Cancel" styleClass="btn-cancel" onAction="#handleCancel" />
            <Button fx:id="btnSave" text="Save Client" styleClass="btn-save" onAction="#handleSaveClient">
                <graphic>
                    <Region styleClass="btn-icon, icon-check" />
                </graphic>
            </Button>
        </HBox>
    </VBox>
</ScrollPane>