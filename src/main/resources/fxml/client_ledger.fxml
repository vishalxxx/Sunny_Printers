<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ClientLedgerController"
            styleClass="client-ledger-root"
            stylesheets="@../css/theme.css, @../css/client_ledger.css">

    <center>
        <ScrollPane fitToWidth="true" styleClass="cl-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
            <VBox spacing="18" alignment="TOP_LEFT" styleClass="cl-page, ui-compact, app-page-shell" fillWidth="true">

                <HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="8"/>
                <!-- Filters -->
                <HBox spacing="16" alignment="CENTER_LEFT" styleClass="info-card-premium, cl-filter-card">
                    <VBox spacing="8" minWidth="220">
                        <Label text="SELECT CLIENT" styleClass="field-heading-sm"/>
                        <ComboBox fx:id="clientCombo" promptText="Select Client" prefWidth="280" minWidth="200" maxWidth="280"
                                  styleClass="taste-combo" onAction="#onClientSelected"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox spacing="14" alignment="BOTTOM_LEFT">
                        <VBox spacing="8">
                            <Label text="TYPE" styleClass="field-heading-sm"/>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <RadioButton fx:id="rbAll" text="All" selected="true">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="typeGroup"/>
                                    </toggleGroup>
                                </RadioButton>
                                <RadioButton fx:id="rbInvoice" text="Invoice" toggleGroup="$typeGroup"/>
                                <RadioButton fx:id="rbPayment" text="Payment" toggleGroup="$typeGroup"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="FROM DATE" styleClass="field-heading-sm"/>
                            <DatePicker fx:id="dateFrom" promptText="Start date" prefWidth="140" maxWidth="160"
                                        styleClass="taste-datepicker" editable="false"/>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="TO DATE" styleClass="field-heading-sm"/>
                            <DatePicker fx:id="dateTo" promptText="End date" prefWidth="140" maxWidth="160"
                                        styleClass="taste-datepicker" editable="false"/>
                        </VBox>

                        <Button onAction="#onReset" styleClass="cl-reset-btn" contentDisplay="GRAPHIC_ONLY"
                                mnemonicParsing="false" focusTraversable="false"
                                style="-fx-background-color: #FFFFFF; -fx-border-color: #CD7B4E; -fx-border-width: 1.4; -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-insets: 0; -fx-min-width: 40; -fx-min-height: 38; -fx-cursor: hand;">
                            <tooltip>
                                <Tooltip text="Show all entries"/>
                            </tooltip>
                            <graphic>
                                <Label text="↻" styleClass="cl-reset-icon" style="-fx-text-fill: #CD7B4E;"/>
                            </graphic>
                        </Button>
                    </HBox>
                </HBox>

                <!-- Summary (shown when client selected) -->
                <HBox fx:id="summaryCard" visible="false" managed="false" styleClass="info-card-premium, cl-summary-card"
                      alignment="CENTER_LEFT" spacing="18">

                    <VBox fx:id="clientDetailsBox" spacing="6" styleClass="cl-detail-block" HBox.hgrow="ALWAYS">
                        <Label fx:id="clientNameLabel" text="Client Name" styleClass="cl-client-name"/>
                        <StackPane fx:id="gstBox" alignment="CENTER_LEFT">
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label fx:id="gstLabel" text="GST: -" styleClass="cl-meta-text"/>
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label text="Location" styleClass="field-heading-sm"/>
                                    <Label fx:id="addressLabel" text="—" styleClass="cl-meta-text" wrapText="true" maxWidth="400"/>
                                </HBox>
                            </HBox>
                        </StackPane>
                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <Label text="Email" styleClass="field-heading-sm"/>
                                <Label fx:id="emailLabel" text="—" styleClass="cl-meta-text"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <Label text="Phone" styleClass="field-heading-sm"/>
                                <Label fx:id="phoneLabel" text="—" styleClass="cl-meta-text"/>
                            </HBox>
                        </HBox>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox styleClass="cl-summary-metrics" spacing="12" alignment="CENTER_LEFT">
                        <VBox styleClass="cl-metric-card, cl-metric-card-due" alignment="CENTER" spacing="2">
                            <Label text="TOTAL DUE" styleClass="cl-metric-label"/>
                            <Label fx:id="totalDueLabel" text="0.00" styleClass="cl-metric-value cl-kpi-due"
                                   style="-fx-text-fill: #7F1D1D; -fx-font-size: 18px; -fx-font-family: 'Manrope'; -fx-font-weight: 800; -fx-opacity: 1;"/>
                        </VBox>
                        <VBox styleClass="cl-metric-card, cl-metric-card-payment" alignment="CENTER" spacing="2">
                            <Label text="PAYMENT" styleClass="cl-metric-label"/>
                            <Label fx:id="paymentLabel" text="0.00" styleClass="cl-metric-value cl-kpi-payment"
                                   style="-fx-text-fill: #14532D; -fx-font-size: 18px; -fx-font-family: 'Manrope'; -fx-font-weight: 800; -fx-opacity: 1;"/>
                        </VBox>
                        <VBox styleClass="cl-metric-card, cl-metric-card-net" alignment="CENTER" spacing="2">
                            <Label text="NET BALANCE" styleClass="cl-metric-label"/>
                            <Label fx:id="netBalanceLabel" text="0.00" styleClass="cl-metric-value cl-kpi-net"
                                   style="-fx-text-fill: #292524; -fx-font-size: 18px; -fx-font-family: 'Manrope'; -fx-font-weight: 800; -fx-opacity: 1;"/>
                        </VBox>
                    </HBox>
                </HBox>

                <!-- Ledger table block -->
                <VBox styleClass="content-card-premium, cl-ledger-wrap" VBox.vgrow="ALWAYS" spacing="0">
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cl-ledger-toolbar">
                        <ImageView fitHeight="18" fitWidth="18" preserveRatio="true" opacity="0.85" styleClass="cl-ledger-icon">
                            <image>
                                <Image url="@../icons/ledger.png"/>
                            </image>
                        </ImageView>
                        <Label text="General Ledger" styleClass="card-title-sm"/>
                        <Label fx:id="recordCountLabel" text="0 Records" styleClass="cl-record-pill"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="searchField" promptText="Search reference, doc…" styleClass="taste-field" prefWidth="220" maxWidth="280"/>
                        <Button text="PRINT" onAction="#onPrint" styleClass="cl-btn cl-btn-soft"
                                contentDisplay="LEFT"
                                style="-fx-background-color: #FFFFFF; -fx-text-fill: #7C2D12; -fx-border-color: #CD7B4E; -fx-border-width: 1.4; -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-insets: 0; -fx-font-size: 12px; -fx-font-weight: 800; -fx-font-family: 'Inter'; -fx-padding: 11 22; -fx-cursor: hand;">
                            <graphic>
                                <Label text="🖨" styleClass="cl-btn-icon" style="-fx-text-fill: #CD7B4E;"/>
                            </graphic>
                        </Button>
                        <Button text="EXPORT" onAction="#onExport" styleClass="cl-btn cl-btn-soft"
                                contentDisplay="LEFT"
                                style="-fx-background-color: #FFFFFF; -fx-text-fill: #7C2D12; -fx-border-color: #CD7B4E; -fx-border-width: 1.4; -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-insets: 0; -fx-font-size: 12px; -fx-font-weight: 800; -fx-font-family: 'Inter'; -fx-padding: 11 22; -fx-cursor: hand;">
                            <graphic>
                                <Label text="↓" styleClass="cl-btn-icon" style="-fx-text-fill: #CD7B4E;"/>
                            </graphic>
                        </Button>
                    </HBox>

                        <TableView fx:id="ledgerTable" styleClass="cl-ledger-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDate" text="DATE" prefWidth="100"/>
                            <TableColumn fx:id="colRef" text="REFERENCE" prefWidth="280"/>
                            <TableColumn fx:id="colReceiptNo" text="RECEIPT NO" prefWidth="130"/>
                            <TableColumn fx:id="colType" text="TYPE" prefWidth="100"/>
                            <TableColumn fx:id="colMode" text="MODE" prefWidth="100"/>
                            <TableColumn fx:id="colDebit" text="DEBIT (-)" prefWidth="110" styleClass="amount-column"/>
                            <TableColumn fx:id="colCredit" text="CREDIT (+)" prefWidth="110" styleClass="amount-column"/>
                            <TableColumn fx:id="colBalance" text="BALANCE" prefWidth="120" styleClass="amount-column"/>
                            <TableColumn fx:id="colStatus" text="STATUS" prefWidth="100"/>
                        </columns>
                    </TableView>

                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cl-ledger-footer">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <HBox styleClass="cl-footer-stat, cl-footer-stat-debit" spacing="8" alignment="CENTER_LEFT">
                                <Label text="TOTAL DEBIT" styleClass="cl-footer-k"/>
                                <Label fx:id="footerTotalDebit" text="₹0.00" styleClass="cl-footer-v"/>
                            </HBox>
                            <HBox styleClass="cl-footer-stat, cl-footer-stat-credit" spacing="8" alignment="CENTER_LEFT">
                                <Label text="TOTAL CREDIT" styleClass="cl-footer-k"/>
                                <Label fx:id="footerTotalCredit" text="₹0.00" styleClass="cl-footer-v"/>
                            </HBox>
                            <HBox styleClass="cl-footer-stat, cl-footer-stat-balance" spacing="8" alignment="CENTER_LEFT">
                                <Label text="CLOSING BALANCE" styleClass="cl-footer-k"/>
                                <Label fx:id="footerClosingBalance" text="₹0.00" styleClass="cl-footer-v"/>
                            </HBox>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox spacing="12" alignment="CENTER_RIGHT">
                            <Button text="CREATE INVOICE" onAction="#onCreateInvoice" styleClass="cl-btn cl-btn-outline"
                                    style="-fx-background-color: #FFFFFF; -fx-text-fill: #3E312D; -fx-border-color: #CD7B4E; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-insets: 0; -fx-font-size: 12px; -fx-font-weight: 800; -fx-font-family: 'Inter'; -fx-padding: 11 22; -fx-cursor: hand;"/>
                            <Button text="+ RECORD PAYMENT" onAction="#onRecordPayment" styleClass="cl-btn cl-btn-primary"
                                    style="-fx-background-color: #CD7B4E; -fx-text-fill: #FFFFFF; -fx-border-color: #B8693C; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-insets: 0; -fx-font-size: 12px; -fx-font-weight: 800; -fx-font-family: 'Inter'; -fx-padding: 11 22; -fx-cursor: hand;"/>
                        </HBox>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
