<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" stylesheets="@../css/edit_client.css" styleClass="center-area"
    xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controller.EditClientController">
    <VBox spacing="30" styleClass="content-container">

        <!-- BREADCRUMBS -->
        <HBox styleClass="breadcrumb-container">
            <Label text="CLIENTS" styleClass="breadcrumb-label" />
            <Label text="›" styleClass="breadcrumb-separator" />
            <Label text="EDIT CLIENT" styleClass="breadcrumb-label, breadcrumb-current" />
        </HBox>

        <!-- HEADER -->
        <HBox styleClass="header-row">
            <Label fx:id="lblTitleName" text="Business Name" styleClass="profile-title"
                HBox.hgrow="ALWAYS" maxWidth="Infinity" />
            <VBox alignment="TOP_RIGHT">
                <Label text="CLIENT ID" styleClass="client-id-label" />
                <Label fx:id="lblClientId" text="#CL-0000" styleClass="client-id-value" />
            </VBox>
        </HBox>

        <VBox spacing="25" fillWidth="true">
            <!-- BASIC INFO -->
            <VBox styleClass="form-card">
                <HBox styleClass="card-header">
                    <Region styleClass="card-icon, icon-basic" />
                    <Label text="Basic Information" styleClass="card-title" />
                </HBox>

                <VBox spacing="18">
                    <VBox>
                        <Label text="BUSINESS NAME" styleClass="field-label" />
                        <TextField fx:id="businessNameField" styleClass="form-input"
                            promptText="Enter business name" />
                    </VBox>
                    <HBox spacing="15">
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="CLIENT NAME" styleClass="field-label" />
                            <TextField fx:id="clientNameField" styleClass="form-input"
                                promptText="Full name" />
                        </VBox>
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="NICK NAME" styleClass="field-label" />
                            <TextField fx:id="nickNameField" styleClass="form-input"
                                promptText="Optional" />
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <!-- CONTACT DETAILS -->
            <VBox styleClass="form-card">
                <HBox styleClass="card-header">
                    <Region styleClass="card-icon, icon-contact" />
                    <Label text="Contact Details" styleClass="card-title" />
                </HBox>

                <VBox spacing="18">
                    <HBox spacing="15">
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="PHONE NUMBER" styleClass="field-label" />
                            <TextField fx:id="phoneField" styleClass="form-input"
                                promptText="+91 0000 0000" />
                        </VBox>
                        <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                            <Label text="ALT. PHONE" styleClass="field-label" />
                            <TextField fx:id="altPhoneField" styleClass="form-input"
                                promptText="Optional" />
                        </VBox>
                    </HBox>
                    <VBox styleClass="input-container-inset">
                        <Label text="EMAIL ADDRESS" styleClass="field-label" />
                        <TextField fx:id="emailField" styleClass="form-input"
                            promptText="email@business.com" />
                    </VBox>
                </VBox>
            </VBox>

            <!-- BUSINESS & TAX INFO -->
            <VBox styleClass="form-card">
                <HBox styleClass="card-header">
                    <Region styleClass="card-icon, icon-tax" />
                    <Label text="Business &amp; Tax Info" styleClass="card-title" />
                </HBox>

                <HBox spacing="20">
                    <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                        <Label text="GST NUMBER" styleClass="field-label" />
                        <TextField fx:id="gstField" styleClass="form-input"
                            promptText="22AAAAA0000A1Z5" />
                    </VBox>
                    <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                        <Label text="PAN NUMBER" styleClass="field-label" />
                        <TextField fx:id="panField" styleClass="form-input" promptText="ABCDE1234F" />
                    </VBox>
                </HBox>
            </VBox>

            <!-- ADDRESS DETAILS -->
            <VBox styleClass="form-card">
                <HBox styleClass="card-header" alignment="CENTER_LEFT">
                    <Region styleClass="card-icon, icon-address" />
                    <Label text="Address Details" styleClass="card-title" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="Same as Billing Address" styleClass="switch-label" />
                    <ToggleButton fx:id="syncAddressToggle" styleClass="ios-toggle">
                        <graphic><Region styleClass="toggle-thumb" /></graphic>
                        <HBox.margin><Insets right="15" /></HBox.margin>
                    </ToggleButton>
                </HBox>

                <HBox spacing="30">
                    <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                        <Label text="BILLING ADDRESS" styleClass="field-label" />
                        <TextArea fx:id="billingAddressField" styleClass="form-textarea"
                            prefHeight="100" promptText="Enter full billing address" wrapText="true" />
                    </VBox>
                    <VBox styleClass="input-container-inset" HBox.hgrow="ALWAYS">
                        <Label text="SHIPPING ADDRESS" styleClass="field-label" />
                        <TextArea fx:id="shippingAddressField" styleClass="form-textarea"
                            prefHeight="100" promptText="Enter full shipping address"
                            wrapText="true" />
                    </VBox>
                </HBox>
            </VBox>

            <!-- NOTES -->
            <VBox styleClass="form-card">
                <HBox styleClass="card-header">
                    <Region styleClass="card-icon, icon-notes" />
                    <Label text="Internal Notes" styleClass="card-title" />
                </HBox>
                <VBox styleClass="input-container-inset">
                    <Label text="CONFIDENTIAL NOTES" styleClass="field-label" />
                    <TextArea fx:id="notesField" styleClass="form-textarea" prefHeight="100"
                        promptText="Any specific reminders for this client..." wrapText="true" />
                </VBox>
            </VBox>
        </VBox>

        <!-- FOOTER -->
        <HBox styleClass="footer-btn-container">
            <Button text="Cancel" styleClass="btn-cancel" onAction="#handleCancel" />
            <Button text="Save Client" styleClass="btn-save" onAction="#handleUpdateClient">
                <graphic>
                    <Region styleClass="btn-icon, icon-check" />
                </graphic>
            </Button>
        </HBox>
    </VBox>
</ScrollPane>