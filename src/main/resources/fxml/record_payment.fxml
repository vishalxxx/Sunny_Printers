<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.RecordPaymentController"
            stylesheets="@../css/theme.css, @../css/record_payment.css"
            styleClass="record-payment-root">

    <center>
        <ScrollPane fitToWidth="true" styleClass="rp-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
            <content>
                <VBox spacing="16" styleClass="rp-page, ui-compact" fillWidth="true">
                    <padding>
                        <Insets top="8" right="20" bottom="24" left="20"/>
                    </padding>

                    <!-- Page intro + outstanding KPI (top right, same as view_client KPIs) -->
                    <HBox alignment="TOP_LEFT" spacing="20">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Record Payment" styleClass="page-heading"/>
                            <Label text="Allocate receipts against outstanding invoices for the selected client."
                                   styleClass="page-subheading"/>
                        </VBox>
                        <VBox styleClass="kpi-card, kpi-card-orange" minWidth="168" maxWidth="220" spacing="6"
                              alignment="CENTER_LEFT">
                            <Label text="TOTAL OUTSTANDING" styleClass="kpi-label"/>
                            <Label fx:id="totalOutstandingLabel" text="₹ 0.00" styleClass="kpi-value-orange"/>
                        </VBox>
                    </HBox>

                    <!-- PAYMENT CARD -->
                    <VBox spacing="16" styleClass="info-card-premium, rp-card">
                        <VBox spacing="8">
                            <Label text="Select client" styleClass="field-heading-sm"/>
                            <ComboBox fx:id="clientCombo" promptText="Select client" maxWidth="Infinity"
                                      styleClass="taste-combo" editable="false"/>
                        </VBox>

                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.3" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="33.3" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="33.4" hgrow="ALWAYS"/>
                            </columnConstraints>

                            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Transaction type" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="paymentTypeCombo" promptText="Payment / Refund" maxWidth="Infinity"
                                          styleClass="taste-combo"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Payment date" styleClass="field-heading-sm"/>
                                <DatePicker fx:id="paymentDatePicker" promptText="Select date" maxWidth="Infinity"
                                            styleClass="taste-datepicker" editable="false"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label text="Payment amount" styleClass="field-heading-sm"/>
                                <TextField fx:id="amountField" promptText="0.00" styleClass="taste-field, rp-amount-field"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Payment mode" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="paymentModeCombo" promptText="Cash / Cheque / UPI / Bank transfer"
                                          maxWidth="Infinity" styleClass="taste-combo"/>
                            </VBox>

                            <VBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="2">
                                <Label text="Notes" styleClass="field-heading-sm"/>
                                <TextField fx:id="notesField" promptText="Transaction remarks (optional)"
                                           styleClass="taste-field"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- CHEQUE DETAILS -->
                    <VBox fx:id="chequeDetailsBox" spacing="14" styleClass="info-card-premium, rp-card" managed="false" visible="false">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="rp-section-icon-wrap">
                                <Region styleClass="rp-section-icon-bank"/>
                            </StackPane>
                            <Label text="Cheque details" styleClass="card-title-sm"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="rp-info-banner">
                            <Label text="This cheque is pending clearance. Invoices stay unpaid until cleared."
                                   styleClass="rp-info-text" wrapText="true"/>
                        </HBox>

                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.3" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="33.3" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="33.4" hgrow="ALWAYS"/>
                            </columnConstraints>

                            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Cheque no." styleClass="field-heading-sm"/>
                                <TextField fx:id="chequeNumberField" promptText="Cheque number" maxWidth="Infinity"
                                           styleClass="taste-field"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Sender bank" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="bankNameCombo" promptText="Select bank" maxWidth="Infinity"
                                          styleClass="taste-combo, rp-bank-combo"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label text="Cheque date" styleClass="field-heading-sm"/>
                                <DatePicker fx:id="chequeDatePicker" promptText="Select date" maxWidth="Infinity"
                                            styleClass="taste-datepicker" editable="false"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Clearance date" styleClass="field-heading-sm"/>
                                <DatePicker fx:id="clearanceDatePicker" promptText="Select date" maxWidth="Infinity"
                                            styleClass="taste-datepicker" editable="false"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="Receiver bank A/C" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="chequeReceiverBankCombo" promptText="Select bank" maxWidth="Infinity"
                                          styleClass="taste-combo"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                <Label text="Status" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="chequeStatusCombo" promptText="Status" maxWidth="Infinity"
                                          styleClass="taste-combo"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- UPI DETAILS -->
                    <VBox fx:id="upiDetailsBox" spacing="14" styleClass="info-card-premium, rp-card" managed="false" visible="false">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="rp-section-icon-wrap">
                                <Region styleClass="rp-section-icon-upi"/>
                            </StackPane>
                            <Label text="UPI details" styleClass="card-title-sm"/>
                        </HBox>

                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.3" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="33.3" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="33.4" hgrow="ALWAYS"/>
                            </columnConstraints>

                            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Sender UPI ID" styleClass="field-heading-sm"/>
                                <TextField fx:id="upiIdField" promptText="name@bank" maxWidth="Infinity" styleClass="taste-field"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="UTR" styleClass="field-heading-sm"/>
                                <TextField fx:id="upiUtrField" promptText="UTR / reference" maxWidth="Infinity" styleClass="taste-field"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label text="Receiver UPI ID" styleClass="field-heading-sm"/>
                                <TextField fx:id="receiverUpiIdField" promptText="receiver@bank" maxWidth="Infinity"
                                           styleClass="taste-field"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Receiver bank A/C" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="upiReceiverBankCombo" promptText="Select bank" maxWidth="Infinity"
                                          styleClass="taste-combo"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="Status" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="upiStatusCombo" promptText="Status" maxWidth="Infinity" styleClass="taste-combo"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- BANK TRANSFER -->
                    <VBox fx:id="bankTransferDetailsBox" spacing="14" styleClass="info-card-premium, rp-card" visible="false" managed="false">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="rp-section-icon-wrap">
                                <Region styleClass="rp-section-icon-transfer"/>
                            </StackPane>
                            <Label text="Bank transfer details" styleClass="card-title-sm"/>
                        </HBox>

                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.3" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="33.3" hgrow="ALWAYS"/>
                                <ColumnConstraints percentWidth="33.4" hgrow="ALWAYS"/>
                            </columnConstraints>

                            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Sender A/C name" styleClass="field-heading-sm"/>
                                <TextField fx:id="senderNameField" promptText="Account holder name" maxWidth="Infinity"
                                           styleClass="taste-field"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Sender A/C number" styleClass="field-heading-sm"/>
                                <TextField fx:id="senderAccountField" promptText="Account number" maxWidth="Infinity"
                                           styleClass="taste-field"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label text="UTR / ref no." styleClass="field-heading-sm"/>
                                <TextField fx:id="bankTransferUtrField" promptText="UTR number" maxWidth="Infinity"
                                           styleClass="taste-field"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Receiver bank A/C" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="receiverBankCombo" promptText="Select bank" maxWidth="Infinity"
                                          styleClass="taste-combo"/>
                            </VBox>

                            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="Status" styleClass="field-heading-sm"/>
                                <ComboBox fx:id="bankTransferStatusCombo" promptText="Status" maxWidth="Infinity"
                                          styleClass="taste-combo"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- INVOICE ALLOCATION TABLE -->
                    <VBox spacing="0" styleClass="content-card-premium, rp-table-card" VBox.vgrow="ALWAYS" minHeight="320">
                        <HBox styleClass="rp-table-header" alignment="CENTER_LEFT" spacing="12">
                            <padding>
                                <Insets top="14" right="16" bottom="14" left="16"/>
                            </padding>
                            <Label text="Allocation against outstanding invoices" styleClass="card-title-sm"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="invoiceCountLabel" text="0 records found" styleClass="rp-muted"/>
                        </HBox>

                        <TableView fx:id="invoiceTable" styleClass="rp-invoice-table" VBox.vgrow="ALWAYS" minHeight="280">
                            <columns>
                                <TableColumn fx:id="selectColumn" text="" prefWidth="56"/>
                                <TableColumn fx:id="invoiceNoColumn" text="Invoice no." prefWidth="130"/>
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                                <TableColumn fx:id="invoiceDateColumn" text="Date" prefWidth="110"/>
                                <TableColumn fx:id="totalAmountColumn" text="Base amt" prefWidth="110"/>
                                <TableColumn fx:id="adjustmentColumn" text="Adjustment" prefWidth="130"/>
                                <TableColumn fx:id="netTotalColumn" text="Net total" prefWidth="110"/>
                                <TableColumn fx:id="netPaidColumn" text="Net paid" prefWidth="110"/>
                                <TableColumn fx:id="dueAmountColumn" text="Due" prefWidth="110"/>
                                <TableColumn fx:id="allocateAmountColumn" text="Allocate" prefWidth="120"/>
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox styleClass="rp-footer" alignment="CENTER_LEFT" spacing="16">
            <padding>
                <Insets top="12" right="20" bottom="12" left="20"/>
            </padding>

            <Label fx:id="footerClientLabel" text="Select client" styleClass="rp-footer-client"/>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="20" alignment="CENTER_LEFT" styleClass="rp-totals-cluster">
                <VBox spacing="2">
                    <Label text="Amount received" styleClass="rp-total-label"/>
                    <Label fx:id="totalEnteredLabel" text="₹ 0.00" styleClass="rp-total-value"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Total allocated" styleClass="rp-total-label"/>
                    <Label fx:id="totalAllocatedLabel" text="₹ 0.00" styleClass="rp-total-value"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Due" styleClass="rp-total-label"/>
                    <Label fx:id="remainingBalanceLabel" text="₹ 0.00" styleClass="rp-total-due"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label fx:id="excessPaymentLabel" text="" visible="false" managed="false" styleClass="rp-excess-pill"/>
                <Button text="Cancel" onAction="#onCancel" styleClass="rp-btn, rp-btn-ghost"/>
                <Button text="Reset" onAction="#onReset" styleClass="rp-btn, rp-btn-outline"/>
                <Button text="Print receipt" onAction="#onPrintReceipt" styleClass="rp-btn, rp-btn-soft"/>
                <Button text="Add payment" onAction="#onAddPayment" styleClass="rp-btn, rp-btn-primary"/>
            </HBox>
        </HBox>
    </bottom>
</BorderPane>
