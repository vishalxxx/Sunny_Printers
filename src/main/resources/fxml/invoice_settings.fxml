<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="settings-master-scroll, settings-theme-root, ui-compact, invoice-settings-root"
            stylesheets="@../css/theme.css, @../css/add_job.css, @../css/view_job.css, @../css/client_edit_selection.css, @../css/settings_screens.css"
            fx:controller="controller.SystemSettingsController">

    <VBox styleClass="settings-page, app-page-shell" alignment="TOP_LEFT" fillWidth="true">

        <HBox fx:id="breadcrumbContainer" styleClass="breadcrumb-container" alignment="CENTER_LEFT" spacing="8"/>

        <HBox styleClass="invoice-numbering-kpi-strip" alignment="CENTER_LEFT" spacing="12" fillHeight="true">
            <VBox styleClass="invoice-kpi-card" spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Focused field" styleClass="invoice-kpi-card-kicker"/>
                <Label fx:id="kpiFocusTitle" styleClass="invoice-kpi-title" wrapText="true"/>
                <Label fx:id="kpiFocusHint" styleClass="invoice-kpi-hint" wrapText="true"/>
            </VBox>
            <VBox styleClass="invoice-kpi-card, invoice-kpi-preview-card" spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="How the number will look" styleClass="invoice-kpi-card-kicker"/>
                <Label fx:id="kpiPreviewValue" styleClass="invoice-kpi-preview-mono" wrapText="true"/>
                <Label fx:id="kpiPreviewCaption" styleClass="invoice-kpi-hint" wrapText="true"/>
            </VBox>
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="16">
            <padding><Insets bottom="8"/></padding>
            <Button text="Save Configuration" fx:id="saveBtn" styleClass="button, btn-primary"/>
        </HBox>

        <!-- Same pattern as General Settings: card + kicker + GridPane (50/50) -->
        <VBox styleClass="settings-form-card" spacing="16" fillWidth="true">
            <Label text="Document numbering" styleClass="card-title-sm"/>
            <Label text="Prefix comes from company name in General Settings. FY is April–March. Payment receipts use the payment id in the number (no separate counter)."
                   wrapText="true" styleClass="settings-section-kicker"/>
            <GridPane hgap="16" vgap="16">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                </columnConstraints>
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Current financial year" styleClass="field-heading-sm"/>
                    <TextField fx:id="fyField" editable="false" styleClass="taste-field" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Digit width" styleClass="field-heading-sm"/>
                    <ComboBox fx:id="paddingCombo" styleClass="taste-combo" maxWidth="Infinity"/>
                </VBox>
            </GridPane>
        </VBox>

        <VBox styleClass="settings-form-card" spacing="16" fillWidth="true">
            <Label text="Next number to assign" styleClass="card-title-sm"/>
            <Label text="Next value issued for each document type (shared format PREFIX/TYPE/FY/####)."
                   wrapText="true" styleClass="settings-section-kicker"/>
            <GridPane fx:id="seriesGrid" hgap="16" vgap="16">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                </columnConstraints>
            </GridPane>
        </VBox>
    </VBox>
</ScrollPane>
