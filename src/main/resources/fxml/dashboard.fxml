<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.Group?>

<StackPane fx:id="appRoot" styleClass="dashboard-root" stylesheets="@../css/modern_dashboard.css" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MainController">

    <BorderPane fx:id="root">
        <!-- LEFT SIDEBAR -->
        <left>
            <StackPane fx:id="sidebarStack" minWidth="60" prefWidth="220" styleClass="sidebar-container">
                <ScrollPane fx:id="sidebarScroll" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0; -fx-border-width: 0;">
                    <StackPane fx:id="contentRoot" alignment="TOP_LEFT">
                        <VBox fx:id="mainSidebar" spacing="20" style="-fx-padding: 30 0 30 0; -fx-alignment: TOP_LEFT;">
                            <!-- Logo Section -->
                            <HBox spacing="15" alignment="CENTER_LEFT" styleClass="sidebar-logo-container">
                                <StackPane style="-fx-background-color: #C87941; -fx-background-radius: 100; -fx-padding: 10; -fx-min-width: 42; -fx-min-height: 42; -fx-max-width: 42; -fx-max-height: 42;">
                                     <Region styleClass="sidebar-icon, icon-jobs" style="-fx-background-color: white; -fx-min-width: 22; -fx-min-height: 22; -fx-max-width: 22; -fx-max-height: 22;"/>
                                </StackPane>
                                <VBox spacing="-2" styleClass="logo-text-box">
                                    <Label text="Sunny Printers" style="-fx-font-size: 17; -fx-font-weight: 800; -fx-text-fill: -fx-text-dark;"/>
                                    <Label text="PRECISION ARTISAN" style="-fx-font-size: 7; -fx-font-weight: 900; -fx-text-fill: -fx-text-muted;"/>
                                </VBox>
                            </HBox>

                            <!-- Navigation -->
                            <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="sidebar-nav-container">
                                <Button onAction="#openDashboard" styleClass="sidebar-btn, sidebar-btn-active" text="Dashboard" maxWidth="Infinity">
                                    <graphic><Region styleClass="sidebar-icon, icon-dashboard"/></graphic>
                                </Button>

                                <!-- CLIENTS SECTION -->
                                <VBox>
                                    <Button fx:id="clientsBtn" onAction="#showClientsSubmenu" styleClass="sidebar-btn" maxWidth="Infinity">
                                        <graphic>
                                            <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="Infinity" styleClass="header-box">
                                                <Region styleClass="sidebar-icon, icon-clients"/>
                                                <Label text="Clients" styleClass="sidebar-label" style="-fx-text-fill: inherit; -fx-font-weight: inherit;"/>
                                                <Region HBox.hgrow="ALWAYS" styleClass="sidebar-spacer"/>
                                                <Region fx:id="clientsChevron" styleClass="chevron-icon"/>
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <VBox fx:id="clientsSubmenu" visible="false" managed="false" spacing="5" styleClass="submenu-container">
                                        <Button onAction="#loadAddClient" styleClass="submenu-btn" text="Add Client">
                                            <graphic><Region styleClass="sidebar-icon, icon-add" style="-fx-background-color: #9CA3AF; -fx-min-width: 12; -fx-min-height: 12;"/></graphic>
                                        </Button>
                                        <Button onAction="#loadViewClients" styleClass="submenu-btn, submenu-btn-active" text="View Clients">
                                            <graphic><Region styleClass="sidebar-icon, icon-dot"/></graphic>
                                        </Button>
                                        <Button onAction="#loadClientLedger" styleClass="submenu-btn" text="Client Reports">
                                            <graphic><Region styleClass="sidebar-icon, icon-ledger" style="-fx-background-color: #9CA3AF; -fx-min-width: 12; -fx-min-height: 12;"/></graphic>
                                        </Button>
                                    </VBox>
                                </VBox>

                                <!-- JOBS SECTION -->
                                <VBox>
                                    <Button fx:id="jobsBtn" onAction="#showJobsSubmenu" styleClass="sidebar-btn" maxWidth="Infinity">
                                        <graphic>
                                            <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="Infinity" styleClass="header-box">
                                                <Region styleClass="sidebar-icon, icon-jobs"/>
                                                <Label text="Jobs" styleClass="sidebar-label" style="-fx-text-fill: inherit; -fx-font-weight: inherit;"/>
                                                <Region HBox.hgrow="ALWAYS" styleClass="sidebar-spacer"/>
                                                <Region fx:id="jobsChevron" styleClass="chevron-icon"/>
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <VBox fx:id="jobsSubmenu" visible="false" managed="false" spacing="5" styleClass="submenu-container">
                                        <Button onAction="#loadAddJob" styleClass="submenu-btn" text="New Print Job">
                                            <graphic><Region styleClass="sidebar-icon, icon-add" style="-fx-background-color: #9CA3AF; -fx-min-width: 12; -fx-min-height: 12;"/></graphic>
                                        </Button>
                                        <Button onAction="#loadViewJob" styleClass="submenu-btn" text="View All Jobs">
                                            <graphic><Region styleClass="sidebar-icon, icon-dot"/></graphic>
                                        </Button>
                                    </VBox>
                                </VBox>

                                <!-- INVOICES SECTION -->
                                <VBox>
                                    <Button fx:id="billingBtn" onAction="#showBillingSubmenu" styleClass="sidebar-btn" maxWidth="Infinity">
                                        <graphic>
                                            <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="Infinity" styleClass="header-box">
                                                <Region styleClass="sidebar-icon, icon-invoices"/>
                                                <Label text="Invoices" styleClass="sidebar-label" style="-fx-text-fill: inherit; -fx-font-weight: inherit;"/>
                                                <Region HBox.hgrow="ALWAYS" styleClass="sidebar-spacer"/>
                                                <Region fx:id="billingChevron" styleClass="chevron-icon"/>
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <VBox fx:id="billingSubmenu" visible="false" managed="false" spacing="5" styleClass="submenu-container">
                                        <Button onAction="#loadInvoiceGenration" styleClass="submenu-btn" text="Generate Invoice">
                                            <graphic><Region styleClass="sidebar-icon, icon-add" style="-fx-background-color: #9CA3AF; -fx-min-width: 12; -fx-min-height: 12;"/></graphic>
                                        </Button>
                                        <Button onAction="#loadViewBills" styleClass="submenu-btn" text="View Invoices">
                                            <graphic><Region styleClass="sidebar-icon, icon-dot"/></graphic>
                                        </Button>
                                        <Button onAction="#loadCreditDebitNote" styleClass="submenu-btn" text="CN / DN Notes">
                                            <graphic><Region styleClass="sidebar-icon, icon-ledger" style="-fx-background-color: #9CA3AF; -fx-min-width: 12; -fx-min-height: 12;"/></graphic>
                                        </Button>
                                    </VBox>
                                </VBox>

                                <!-- PAYMENTS SECTION -->
                                <VBox>
                                    <Button fx:id="paymentBtn" onAction="#showPaymentSubmenu" styleClass="sidebar-btn" maxWidth="Infinity">
                                        <graphic>
                                            <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="Infinity" styleClass="header-box">
                                                <Region styleClass="sidebar-icon, icon-payments"/>
                                                <Label text="Payments" styleClass="sidebar-label" style="-fx-text-fill: inherit; -fx-font-weight: inherit;"/>
                                                <Region HBox.hgrow="ALWAYS" styleClass="sidebar-spacer"/>
                                                <Region fx:id="paymentChevron" styleClass="chevron-icon"/>
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <VBox fx:id="paymentSubmenu" visible="false" managed="false" spacing="5" styleClass="submenu-container">
                                        <Button onAction="#loadRecordPayment" styleClass="submenu-btn" text="Record Payment">
                                            <graphic><Region styleClass="sidebar-icon, icon-add" style="-fx-background-color: #9CA3AF; -fx-min-width: 12; -fx-min-height: 12;"/></graphic>
                                        </Button>
                                        <Button onAction="#loadPaymentHistory" styleClass="submenu-btn" text="Payment History">
                                            <graphic><Region styleClass="sidebar-icon, icon-dot"/></graphic>
                                        </Button>
                                    </VBox>
                                </VBox>

                                <!-- LEDGER SECTION -->
                                <VBox>
                                    <Button fx:id="ledgerBtn" onAction="#showLedgerSubmenu" styleClass="sidebar-btn" maxWidth="Infinity">
                                        <graphic>
                                            <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="Infinity" styleClass="header-box">
                                                <Region styleClass="sidebar-icon, icon-ledger"/>
                                                <Label text="Ledger" styleClass="sidebar-label" style="-fx-text-fill: inherit; -fx-font-weight: inherit;"/>
                                                <Region HBox.hgrow="ALWAYS" styleClass="sidebar-spacer"/>
                                                <Region fx:id="ledgerChevron" styleClass="chevron-icon"/>
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <VBox fx:id="ledgerSubmenu" visible="false" managed="false" spacing="5" styleClass="submenu-container">
                                        <Button onAction="#loadClientLedger" styleClass="submenu-btn" text="Client Ledger">
                                            <graphic><Region styleClass="sidebar-icon, icon-dot"/></graphic>
                                        </Button>
                                    </VBox>
                                </VBox>

                                <!-- SETTINGS SECTION -->
                                <VBox>
                                    <Button fx:id="settingsBtn" onAction="#showSettingSubmenu" styleClass="sidebar-btn" maxWidth="Infinity">
                                        <graphic>
                                            <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="Infinity" styleClass="header-box">
                                                <Region styleClass="sidebar-icon, icon-settings"/>
                                                <Label text="Settings" styleClass="sidebar-label" style="-fx-text-fill: inherit; -fx-font-weight: inherit;"/>
                                                <Region HBox.hgrow="ALWAYS" styleClass="sidebar-spacer"/>
                                                <Region fx:id="settingsChevron" styleClass="chevron-icon"/>
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <VBox fx:id="settingsSubmenu" visible="false" managed="false" spacing="5" styleClass="submenu-container">
                                        <Button onAction="#loadGeneralSettings" styleClass="submenu-btn" text="General Settings">
                                            <graphic><Region styleClass="sidebar-icon, icon-dot"/></graphic>
                                        </Button>
                                        <Button onAction="#loadInvoiceSettings" styleClass="submenu-btn" text="Invoice Templates">
                                            <graphic><Region styleClass="sidebar-icon, icon-brush" style="-fx-background-color: #9CA3AF; -fx-min-width: 12; -fx-min-height: 12;"/></graphic>
                                        </Button>
                                        <Button onAction="#loadUserSettings" styleClass="submenu-btn" text="User Permissions">
                                            <graphic><Region styleClass="sidebar-icon, icon-clients" style="-fx-background-color: #9CA3AF; -fx-min-width: 12; -fx-min-height: 12;"/></graphic>
                                        </Button>
                                    </VBox>
                                </VBox>

                                <Region VBox.vgrow="ALWAYS"/>
                                <VBox style="-fx-padding: 30 0 0 0;">
                                    <Button onAction="#loadAddJob" styleClass="new-job-btn" text="New Print Job" maxWidth="Infinity">
                                        <graphic><Region styleClass="sidebar-icon, icon-add"/></graphic>
                                    </Button>
                                </VBox>
                            </VBox>
                        </VBox>


                    </StackPane>
                </ScrollPane>
            </StackPane>
        </left>

        <!-- MAIN AREA -->
        <center>
            <StackPane fx:id="centerContentHost">
                <VBox fx:id="centerRoot" spacing="0">
                    <!-- HEADER Aligned with Logo (Top Pdg 22px) -->
                    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 22 50 10 50;">
                        <HBox alignment="CENTER" spacing="12" styleClass="search-field" prefWidth="380">
                             <Region styleClass="sidebar-icon, icon-search" style="-fx-background-color: -fx-text-muted; -fx-min-width: 16; -fx-min-height: 16;"/>
                             <TextField promptText="Search orders..." style="-fx-background-color: transparent; -fx-padding: 0; -fx-font-size: 14;" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        
                        <Region HBox.hgrow="ALWAYS"/>
                        
                        <HBox spacing="10" alignment="CENTER">
                            <!-- Notification Icon -->
                            <StackPane styleClass="header-icon-btn">
                                <Region styleClass="sidebar-icon, icon-notification" style="-fx-background-color: #716D68; -fx-min-width: 18; -fx-min-height: 18;"/>
                            </StackPane>
                            
                            <!-- Help Icon -->
                            <StackPane styleClass="header-icon-btn">
                                <Region styleClass="sidebar-icon, icon-help" style="-fx-background-color: #716D68; -fx-min-width: 18; -fx-min-height: 18;"/>
                            </StackPane>
                            
                            <Separator orientation="VERTICAL" prefHeight="24" style="-fx-opacity: 0.1; -fx-padding: 0 5;"/>
                            
                            <!-- User Profile -->
                            <HBox spacing="12" alignment="CENTER">
                                <VBox alignment="CENTER_RIGHT" spacing="0">
                                    <Label fx:id="pageTitle" text="Alex Mercer" style="-fx-font-weight: 800; -fx-text-fill: -fx-text-dark; -fx-font-size: 14;"/>
                                    <Label text="PRODUCTION MANAGER" style="-fx-font-size: 8; -fx-font-weight: 900; -fx-text-fill: -fx-text-muted; -fx-letter-spacing: 0.5;"/>
                                </VBox>
                                <StackPane styleClass="profile-avatar">
                                    <Circle radius="22" fill="#EBE7DE"/>
                                    <Label text="AM" style="-fx-font-weight: 800; -fx-text-fill: #8E857C; -fx-font-size: 14;"/>
                                </StackPane>
                            </HBox>
                        </HBox>
                    </HBox>

                    <!-- CONTENT -->
                    <ScrollPane fx:id="dashboardView" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <!-- CONTENT with Horizontal scaling and Tightened Top Buffer -->
                            <VBox spacing="20" style="-fx-padding: 12 50 40 50;">
                            
                            <!-- DASHBOARD HEADER -->
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <VBox spacing="2">
                                    <Label fx:id="lblDashboardGreeting" text="Welcome" style="-fx-font-size: 24; -fx-font-weight: 800; -fx-text-fill: -fx-text-dark;"/>
                                    <Label text="Precision insights for Sunny Printers Artisan team." style="-fx-font-size: 11; -fx-text-fill: -fx-text-muted; -fx-font-style: italic;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <HBox spacing="15" alignment="CENTER">
                                    <Button text="Last 30 Days" styleClass="action-pill-white">
                                        <graphic><Region styleClass="sidebar-icon" style="-fx-shape: 'M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z'; -fx-background-color: -fx-text-dark; -fx-min-width: 14; -fx-min-height: 14;"/></graphic>
                                    </Button>
                                    <Button text="Export Report" styleClass="action-pill-orange">
                                        <graphic><Region styleClass="sidebar-icon" style="-fx-shape: 'M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z'; -fx-background-color: white; -fx-min-width: 14; -fx-min-height: 14;"/></graphic>
                                    </Button>
                                </HBox>
                            </HBox>

                            <!-- NEW KPI CARDS ROW -->
                            <HBox spacing="25" alignment="CENTER">
                                <!-- CARD 1 -->
                                <VBox styleClass="dashboard-kpi-card" HBox.hgrow="ALWAYS" spacing="15">
                                    <Label text="TOTAL REVENUE" styleClass="kpi-title"/>
                                    <HBox alignment="BASELINE_LEFT" spacing="8">
                                        <Label text="₹1,28,450" styleClass="kpi-value"/>
                                        <Label text="+12%" styleClass="kpi-percent" style="-fx-text-fill: #5D6356;"/>
                                    </HBox>
                                    <StackPane styleClass="kpi-progress-bg">
                                        <Region styleClass="kpi-progress-fill, kpi-fill-revenue" style="-fx-max-width: 120; -fx-alignment: CENTER_LEFT;"/>
                                    </StackPane>
                                </VBox>
                                
                                <!-- CARD 2 -->
                                <VBox styleClass="dashboard-kpi-card" HBox.hgrow="ALWAYS" spacing="15">
                                    <Label text="OUTSTANDING AMOUNT" styleClass="kpi-title"/>
                                    <HBox alignment="BASELINE_LEFT" spacing="8">
                                        <Label text="₹42,120" styleClass="kpi-value"/>
                                        <Label text="+4%" styleClass="kpi-percent" style="-fx-text-fill: #EF4444;"/>
                                    </HBox>
                                    <StackPane styleClass="kpi-progress-bg">
                                        <Region styleClass="kpi-progress-fill, kpi-fill-revenue" style="-fx-max-width: 60; -fx-alignment: CENTER_LEFT;"/>
                                    </StackPane>
                                </VBox>

                                <!-- CARD 3 -->
                                <VBox styleClass="dashboard-kpi-card" HBox.hgrow="ALWAYS" spacing="15">
                                    <Label text="COLLECTED THIS MONTH" styleClass="kpi-title"/>
                                    <HBox alignment="BASELINE_LEFT" spacing="8">
                                        <Label text="₹18,900" styleClass="kpi-value"/>
                                        <Label text="+8%" styleClass="kpi-percent" style="-fx-text-fill: #5D6356;"/>
                                    </HBox>
                                    <StackPane styleClass="kpi-progress-bg">
                                        <Region styleClass="kpi-progress-fill, kpi-fill-collected" style="-fx-max-width: 80; -fx-alignment: CENTER_LEFT;"/>
                                    </StackPane>
                                </VBox>

                                <!-- CARD 4 -->
                                <VBox styleClass="dashboard-kpi-card" HBox.hgrow="ALWAYS" spacing="15">
                                    <Label text="OVERDUE AMOUNT" styleClass="kpi-title">
                                        <style>-fx-text-fill: #EF4444;</style>
                                    </Label>
                                    <HBox alignment="BASELINE_LEFT" spacing="8">
                                        <Label text="₹6,240" styleClass="kpi-value" style="-fx-text-fill: #EF4444;"/>
                                        <Label text="-2%" styleClass="kpi-percent" style="-fx-text-fill: #EF4444;"/>
                                    </HBox>
                                    <StackPane styleClass="kpi-progress-bg">
                                        <Region styleClass="kpi-progress-fill, kpi-fill-overdue" style="-fx-max-width: 40; -fx-alignment: CENTER_LEFT;"/>
                                    </StackPane>
                                </VBox>
                            </HBox>
                            
                            <!-- PRODUCTION PIPELINE CARD -->
                            <VBox styleClass="pipeline-container" spacing="30">
                                <HBox alignment="CENTER_LEFT">
                                    <VBox spacing="5">
                                        <Label text="Production Pipeline" style="-fx-font-size: 24; -fx-font-weight: 800; -fx-text-fill: -fx-text-dark;"/>
                                        <Label text="Crafting excellence through every stage" style="-fx-font-size: 14; -fx-text-fill: -fx-text-muted;"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <HBox spacing="15" alignment="CENTER">
                                        <Label text="42 Active Jobs" style="-fx-background-color: rgba(255,255,255,0.4); -fx-padding: 8 18; -fx-background-radius: 20; -fx-font-weight: 700; -fx-font-size: 12; -fx-text-fill: -fx-text-muted;"/>
                                        <Button text="Add Job" styleClass="action-pill-orange" style="-fx-padding: 8 20; -fx-font-size: 12;">
                                            <graphic><Region styleClass="sidebar-icon" style="-fx-shape: 'M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z'; -fx-background-color: white; -fx-min-width: 12; -fx-min-height: 12;"/></graphic>
                                        </Button>
                                    </HBox>
                                </HBox>

                                <HBox alignment="CENTER" spacing="0">
                                    <VBox alignment="CENTER" spacing="15" prefWidth="150">
                                        <StackPane styleClass="pipeline-icon-circle">
                                            <Region styleClass="icon-brush" style="-fx-background-color: #8E4D21; -fx-min-width: 32; -fx-min-height: 32; -fx-max-width: 32; -fx-max-height: 32;"/>
                                        </StackPane>
                                        <VBox alignment="CENTER" spacing="2">
                                            <Label text="Pre Press" styleClass="pipeline-label"/>
                                            <HBox alignment="CENTER" spacing="4">
                                                <Label text="12" style="-fx-font-weight: 800; -fx-text-fill: #C87941; -fx-font-size: 18;"/>
                                                <Label text="(28%)" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11;"/>
                                            </HBox>
                                        </VBox>
                                    </VBox>
                                    
                                    <Label text="›" style="-fx-font-size: 24; -fx-text-fill: -fx-text-muted; -fx-opacity: 0.3; -fx-padding: 0 10;"/>
                                    
                                    <VBox alignment="CENTER" spacing="15" prefWidth="150">
                                        <StackPane styleClass="pipeline-icon-circle">
                                            <Region styleClass="icon-printer" style="-fx-background-color: #8E4D21; -fx-min-width: 32; -fx-min-height: 32; -fx-max-width: 32; -fx-max-height: 32;"/>
                                        </StackPane>
                                        <VBox alignment="CENTER" spacing="2">
                                            <Label text="Printing" styleClass="pipeline-label"/>
                                            <HBox alignment="CENTER" spacing="4">
                                                <Label text="18" style="-fx-font-weight: 800; -fx-text-fill: #C87941; -fx-font-size: 18;"/>
                                                <Label text="(43%)" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11;"/>
                                            </HBox>
                                        </VBox>
                                    </VBox>

                                    <Label text="›" style="-fx-font-size: 24; -fx-text-fill: -fx-text-muted; -fx-opacity: 0.3; -fx-padding: 0 10;"/>

                                    <VBox alignment="CENTER" spacing="15" prefWidth="150">
                                        <StackPane styleClass="pipeline-icon-circle">
                                            <Region styleClass="icon-layers" style="-fx-background-color: #8E4D21; -fx-min-width: 32; -fx-min-height: 32; -fx-max-width: 32; -fx-max-height: 32;"/>
                                        </StackPane>
                                        <VBox alignment="CENTER" spacing="2">
                                            <Label text="Finishing" styleClass="pipeline-label"/>
                                            <HBox alignment="CENTER" spacing="4">
                                                <Label text="8" style="-fx-font-weight: 800; -fx-text-fill: #C87941; -fx-font-size: 18;"/>
                                                <Label text="(19%)" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11;"/>
                                            </HBox>
                                        </VBox>
                                    </VBox>

                                    <Label text="›" style="-fx-font-size: 24; -fx-text-fill: -fx-text-muted; -fx-opacity: 0.3; -fx-padding: 0 10;"/>

                                    <VBox alignment="CENTER" spacing="15" prefWidth="150">
                                        <StackPane styleClass="pipeline-icon-circle, pipeline-icon-ready">
                                            <StackPane style="-fx-background-color: white; -fx-background-radius: 100; -fx-min-width: 32; -fx-max-width: 32; -fx-min-height: 32; -fx-max-height: 32;">
                                                <Region styleClass="icon-check" style="-fx-background-color: #5D6356; -fx-min-width: 16; -fx-min-height: 16; -fx-max-width: 16; -fx-max-height: 16;"/>
                                            </StackPane>
                                        </StackPane>
                                        <VBox alignment="CENTER" spacing="2">
                                            <Label text="Ready" styleClass="pipeline-label"/>
                                            <HBox alignment="CENTER" spacing="4">
                                                <Label text="4" style="-fx-font-weight: 800; -fx-text-fill: #5D6356; -fx-font-size: 18;"/>
                                                <Label text="(10%)" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11;"/>
                                            </HBox>
                                        </VBox>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <!-- CHARTS ROW -->
                            <HBox spacing="30">
                                <!-- Revenue Analysis (Was AreaChart in controller) -->
                                <VBox styleClass="dashboard-kpi-card" HBox.hgrow="ALWAYS" spacing="20">
                                    <HBox alignment="CENTER_LEFT">
                                        <VBox spacing="4">
                                            <Label text="Cash Flow Analysis" style="-fx-font-size: 18; -fx-font-weight: 800; -fx-text-fill: -fx-text-dark;"/>
                                            <Label text="Revenue vs expenditures" style="-fx-font-size: 13; -fx-text-fill: -fx-text-muted;"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <HBox spacing="10" style="-fx-background-color: #F8F5EE; -fx-padding: 4; -fx-background-radius: 100;">
                                            <Button text="1M" onAction="#handleChartRange1M" style="-fx-background-color: white; -fx-background-radius: 100; -fx-font-size: 10; -fx-font-weight: 800; -fx-padding: 4 12;"/>
                                            <Button text="3M" onAction="#handleChartRange3M" style="-fx-background-color: transparent; -fx-font-size: 10; -fx-font-weight: 700; -fx-padding: 4 12;"/>
                                            <Button text="6M" onAction="#handleChartRange6M" style="-fx-background-color: transparent; -fx-font-size: 10; -fx-font-weight: 700; -fx-padding: 4 12;"/>
                                        </HBox>
